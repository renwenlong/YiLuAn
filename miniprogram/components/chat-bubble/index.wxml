<view class="chat-bubble-wrapper {{isMine ? 'mine' : 'other'}}">
  <text class="sender-name" wx:if="{{!isMine}}">{{message.sender_name}}</text>
  <view class="bubble {{isMine ? 'bubble-mine' : 'bubble-other'}}">
    <text class="bubble-content">{{message.content}}</text>
  </view>
  <text class="bubble-time">{{message.created_at}}</text>
</view>
