.page-container {
  padding: 24rpx;
  padding-bottom: 40rpx;
  min-height: 100vh;
  background-color: #f5f5f5;
  box-sizing: border-box;
}

.order-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.order-card-wrapper {
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.accept-action {
  padding: 16rpx 24rpx 24rpx;
  display: flex;
  justify-content: flex-end;
}

.btn-accept {
  width: 200rpx;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 28rpx;
  background-color: #4CAF50;
  color: #fff;
  border-radius: 12rpx;
  font-weight: bold;
  padding: 0;
}

.btn-accept:active {
  background-color: #388E3C;
}

.load-more,
.no-more {
  text-align: center;
  padding: 32rpx 0;
  font-size: 26rpx;
  color: #999;
}
