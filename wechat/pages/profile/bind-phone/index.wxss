.bind-phone-page {
  min-height: 100vh;
  background-color: #F5F5F5;
  padding: 24rpx;
}

.form-section {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 32rpx;
}

.form-group {
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333333;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  border: 1rpx solid #D9D9D9;
  border-radius: 8rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
}

.phone-row {
  display: flex;
  align-items: center;
}

.phone-input {
  flex: 1;
  margin-right: 16rpx;
}

.otp-btn {
  width: 220rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #1890FF;
  color: #FFFFFF;
  font-size: 24rpx;
  border-radius: 8rpx;
  border: none;
  flex-shrink: 0;
  padding: 0;
}

.otp-btn[disabled] {
  background-color: #B5B5B5;
  color: #FFFFFF;
}

.otp-btn::after {
  border: none;
}

.btn-section {
  margin-top: 48rpx;
}

.btn-bind {
  width: 100%;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #1890FF;
  color: #FFFFFF;
  font-size: 32rpx;
  border-radius: 12rpx;
  border: none;
  font-weight: 600;
}

.btn-bind:active {
  background-color: #096DD9;
}

.btn-bind[disabled] {
  background-color: #B5B5B5;
  color: #FFFFFF;
}

.btn-bind::after {
  border: none;
}
