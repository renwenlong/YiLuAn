<view class="profile-page">
  <!-- User Info Section -->
  <view class="user-section">
    <view class="user-info">
      <view class="user-avatar" bindtap="onAvatarTap">
        <image wx:if="{{user.avatar}}" src="{{user.avatar}}" class="avatar-img" />
        <view wx:else class="avatar-placeholder">
          <text>{{user.name[0] || '用'}}</text>
        </view>
        <view class="avatar-edit-hint">
          <text>换</text>
        </view>
      </view>
      <view class="user-detail">
        <view class="user-name-row">
          <text class="user-name">{{user.name || '用户'}}</text>
          <text wx:if="{{user.role === 'companion'}}" class="role-badge companion-badge">陪诊师</text>
          <text wx:elif="{{user.role === 'patient'}}" class="role-badge patient-badge">患者</text>
        </view>

        <view class="user-phone" wx:if="{{user.phone}}">
          <text class="phone-text">{{user.phone}}</text>
        </view>
        <view class="user-phone bind-phone" wx:else bindtap="onBindPhone">
          <text class="phone-text unbind">未绑定手机</text>
          <text class="bind-btn">去绑定</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Menu List -->
  <view class="menu-section">
    <view class="menu-item" data-target="/pages/profile/edit/index" bindtap="onMenuTap">
      <text class="menu-text">编辑资料</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" data-target="/pages/orders/index" bindtap="onMenuTap">
      <text class="menu-text">我的订单</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" data-target="/pages/profile/wallet/index" bindtap="onMenuTap">
      <text class="menu-text">我的钱包</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" data-target="/pages/profile/emergency-contacts/index" bindtap="onMenuTap">
      <text class="menu-text">紧急联系人</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" data-target="/pages/profile/settings/index" bindtap="onMenuTap">
      <text class="menu-text">设置</text>
      <text class="menu-arrow">></text>
    </view>
  </view>

  <!-- Logout -->
  <view class="logout-section">
    <button class="logout-btn" bindtap="onLogout">退出登录</button>
  </view>
</view>

<patient-tab-bar active="profile" />
