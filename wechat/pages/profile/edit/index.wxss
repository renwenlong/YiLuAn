.edit-page {
  min-height: 100vh;
  background-color: #F5F5F5;
  padding: 24rpx;
}

.form-section {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 32rpx;
}

.form-group {
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333333;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  border: 1rpx solid #D9D9D9;
  border-radius: 8rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  min-height: 200rpx;
  border: 1rpx solid #D9D9D9;
  border-radius: 8rpx;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
}

.btn-section {
  margin-top: 48rpx;
}

.btn-save {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background-color: #1890FF;
  color: #FFFFFF;
  font-size: 32rpx;
  border-radius: 12rpx;
  border: none;
  font-weight: 600;
}

.btn-save:active {
  background-color: #096DD9;
}

.btn-save[disabled] {
  background-color: #B5B5B5;
  color: #FFFFFF;
}

.btn-save::after {
  border: none;
}

.loading-section {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 120rpx 0;
  color: #999999;
  font-size: 28rpx;
}
