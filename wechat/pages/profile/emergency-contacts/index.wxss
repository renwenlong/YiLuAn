.page { padding: 24rpx; }
.hint { color: #888; font-size: 26rpx; padding: 16rpx 0 24rpx; }
.contact-list { display: flex; flex-direction: column; gap: 16rpx; }
.contact-card { background: #fff; padding: 24rpx; border-radius: 12rpx; display: flex; justify-content: space-between; align-items: center; }
.contact-name { font-size: 32rpx; font-weight: 500; color: #333; }
.contact-rel { font-size: 24rpx; color: #666; margin-left: 12rpx; font-weight: normal; }
.contact-phone { font-size: 28rpx; color: #555; margin-top: 6rpx; }
.contact-actions { display: flex; gap: 24rpx; }
.link-btn { color: #1890FF; font-size: 28rpx; }
.link-danger { color: #e53935; }
.empty { text-align: center; color: #aaa; padding: 60rpx 0; }
.add-btn { margin-top: 32rpx; background: #1890FF; color: #fff; border-radius: 12rpx; }
.add-btn[disabled] { background: #ccc; color: #fff; }
.modal-mask { position: fixed; left: 0; right: 0; top: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 100; }
.modal { position: fixed; left: 40rpx; right: 40rpx; top: 30%; background: #fff; border-radius: 16rpx; padding: 32rpx; z-index: 101; }
.modal-title { font-size: 32rpx; font-weight: bold; margin-bottom: 24rpx; }
.form-row { display: flex; align-items: center; padding: 16rpx 0; border-bottom: 1rpx solid #eee; }
.form-label { width: 140rpx; color: #666; font-size: 28rpx; }
.form-input { flex: 1; font-size: 28rpx; }
.modal-actions { display: flex; gap: 16rpx; margin-top: 32rpx; }
.modal-actions .btn-primary { flex: 1; background: #1890FF; color: #fff; border-radius: 12rpx; }
.modal-actions .btn-secondary { flex: 1; background: #f0f0f0; color: #333; border-radius: 12rpx; }
