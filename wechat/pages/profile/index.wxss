.profile-page {
  min-height: 100vh;
  background-color: var(--color-bg-page);
  padding-bottom: 120rpx;
}

/* User Info Section */
.user-section {
  background-color: var(--color-bg-card);
  padding: 48rpx 32rpx;
  margin-bottom: 20rpx;
}

.user-info {
  display: flex;
  align-items: center;
}

.user-avatar {
  margin-right: 24rpx;
  flex-shrink: 0;
  position: relative;
}

.avatar-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
}

.avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background-color: var(--color-primary);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-placeholder text {
  font-size: 44rpx;
  color: var(--color-text-white);
  font-weight: 600;
}

.avatar-edit-hint {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-edit-hint text {
  font-size: 20rpx;
  color: var(--color-text-white);
}

.user-detail {
  flex: 1;
}

.user-name-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.user-name {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.role-badge {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
  margin-left: 12rpx;
}

.patient-badge {
  background-color: var(--color-primary-light);
  color: var(--color-primary);
}

.companion-badge {
  background-color: #F6FFED;
  color: var(--color-success);
}


.user-phone {
  display: flex;
  align-items: center;
}

.phone-text {
  font-size: 28rpx;
  color: var(--color-text-hint);
}

.phone-text.unbind {
  color: var(--color-warning);
}

.bind-phone {
  display: flex;
  align-items: center;
}

.bind-btn {
  font-size: 24rpx;
  color: var(--color-primary);
  margin-left: 12rpx;
}

/* Menu List */
.menu-section {
  background-color: var(--color-bg-card);
  margin-bottom: 20rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid var(--color-border-light);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background-color: var(--color-bg-page);
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: var(--color-text-primary);
}

.menu-arrow {
  font-size: 28rpx;
  color: #CCCCCC;
}

/* Logout */
.logout-section {
  padding: 40rpx 32rpx;
}

.logout-btn {
  width: 100%;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--color-bg-card);
  color: var(--color-danger);
  font-size: 30rpx;
  border-radius: 12rpx;
  border: none;
}

.logout-btn::after {
  border: none;
}
