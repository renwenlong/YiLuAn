.settings-page {
  min-height: 100vh;
  background-color: #F5F5F5;
}

.settings-section {
  background-color: #FFFFFF;
  margin-top: 20rpx;
}

.settings-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.settings-item:last-child {
  border-bottom: none;
}

.settings-item:active {
  background-color: #F5F5F5;
}

.item-label {
  font-size: 30rpx;
  color: #333333;
}

.item-right {
  display: flex;
  align-items: center;
}

.item-value {
  font-size: 28rpx;
  color: #999999;
  margin-right: 12rpx;
}

.item-arrow {
  font-size: 28rpx;
  color: #CCCCCC;
}

/* 城市选择弹窗 */
.city-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.city-modal {
  width: 100%;
  max-height: 70vh;
  background: #FFFFFF;
  border-radius: 24rpx 24rpx 0 0;
  display: flex;
  flex-direction: column;
}

.city-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.city-modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.city-modal-close {
  font-size: 36rpx;
  color: #999999;
  padding: 0 8rpx;
}

.city-modal-body {
  padding: 16rpx 32rpx 48rpx;
  overflow-y: auto;
  max-height: 60vh;
}

.city-option {
  display: flex;
  align-items: center;
  padding: 28rpx 16rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.city-option:active {
  background: #F5F5F5;
}

.city-option.active {
  background: #E6F7FF;
}

.city-option-locate {
  background: #F0F5FF;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  border-bottom: none;
}

.city-option-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.city-option-text {
  font-size: 30rpx;
  color: #333333;
  flex: 1;
}

.city-option-hint {
  font-size: 26rpx;
  color: #1890FF;
}

.city-option-check {
  font-size: 32rpx;
  color: #1890FF;
  font-weight: 600;
}

.city-list-title {
  font-size: 26rpx;
  color: #999999;
  padding: 20rpx 0 8rpx;
}
