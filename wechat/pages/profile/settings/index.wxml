<view class="settings-page">
  <view class="settings-section">
    <view class="settings-item" wx:if="{{user.role === 'companion'}}" bindtap="onCityTap">
      <text class="item-label">我的城市</text>
      <view class="item-right">
        <text class="item-value">{{city || '未设置'}}</text>
        <text class="item-arrow">></text>
      </view>
    </view>
    <view class="settings-item" bindtap="onSwitchRole">
      <text class="item-label">切换为{{user.role === 'patient' ? '陪诊师' : '患者'}}</text>
      <view class="item-right">
        <text class="item-value">当前：{{user.role === 'patient' ? '患者' : '陪诊师'}}</text>
        <text class="item-arrow">></text>
      </view>
    </view>
    <view class="settings-item" bindtap="onChangePhone">
      <text class="item-label">我的手机号</text>
      <view class="item-right">
        <text class="item-value">{{user.phone || '未绑定'}}</text>
        <text class="item-arrow">></text>
      </view>
    </view>
    <view class="settings-item" bindtap="onClearCache">
      <text class="item-label">清除缓存</text>
      <view class="item-right">
        <text class="item-value">{{cacheSize}}</text>
        <text class="item-arrow">></text>
      </view>
    </view>
    <view class="settings-item" bindtap="onAbout">
      <text class="item-label">关于</text>
      <view class="item-right">
        <text class="item-arrow">></text>
      </view>
    </view>
  </view>

  <!-- 城市选择弹窗 -->
  <view class="city-modal-mask" wx:if="{{showCityPicker}}" bindtap="onCloseCityPicker">
    <view class="city-modal" catchtap>
      <view class="city-modal-header">
        <text class="city-modal-title">选择城市</text>
        <text class="city-modal-close" bindtap="onCloseCityPicker">✕</text>
      </view>
      <view class="city-modal-body">
        <view class="city-option city-option-locate" bindtap="onAutoLocate">
          <text class="city-option-icon">📍</text>
          <text class="city-option-text">自动定位</text>
          <text class="city-option-hint" wx:if="{{locating}}">定位中...</text>
        </view>
        <view class="city-list-title" wx:if="{{allCities.length > 0}}">
          <text>可选城市</text>
        </view>
        <view
          class="city-option {{city === item ? 'active' : ''}}"
          wx:for="{{allCities}}"
          wx:key="*this"
          data-city="{{item}}"
          bindtap="onSelectCity"
        >
          <text class="city-option-text">{{item}}</text>
          <text class="city-option-check" wx:if="{{city === item}}">✓</text>
        </view>
      </view>
    </view>
  </view>
</view>
