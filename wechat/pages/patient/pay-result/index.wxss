.result-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 48rpx 48rpx;
}

.icon-circle {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
}

.icon-text {
  font-size: 80rpx;
  color: var(--color-text-white);
  font-weight: bold;
}

.success-bg { background-color: var(--color-success); }
.fail-bg { background-color: var(--color-danger); }
.cancel-bg { background-color: var(--color-warning); }

.result-title {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--color-text-primary);
  margin-bottom: 16rpx;
}

.result-desc {
  font-size: 28rpx;
  color: var(--color-text-hint);
  text-align: center;
  margin-bottom: 64rpx;
  line-height: 1.5;
}

.btn-primary {
  width: 80%;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  background-color: var(--color-success);
  color: var(--color-text-white);
  border-radius: 16rpx;
  font-weight: bold;
  margin-bottom: 24rpx;
}

.btn-secondary {
  width: 80%;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  background-color: var(--color-bg-page);
  color: var(--color-text-secondary);
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}
