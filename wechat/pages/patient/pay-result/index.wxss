.result-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 48rpx 48rpx;
}

.icon-circle {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
}

.icon-text {
  font-size: 80rpx;
  color: #fff;
  font-weight: bold;
}

.success-bg { background-color: #4CAF50; }
.fail-bg { background-color: #F44336; }
.cancel-bg { background-color: #FF9800; }

.result-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.result-desc {
  font-size: 28rpx;
  color: #999;
  text-align: center;
  margin-bottom: 64rpx;
  line-height: 1.5;
}

.btn-primary {
  width: 80%;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  background-color: #4CAF50;
  color: #fff;
  border-radius: 16rpx;
  font-weight: bold;
  margin-bottom: 24rpx;
}

.btn-secondary {
  width: 80%;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  background-color: #f5f5f5;
  color: #666;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}
