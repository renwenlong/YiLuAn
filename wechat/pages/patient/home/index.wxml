<view class="patient-home">
  <!-- 选择服务 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">选择服务</text>
    </view>
    <view class="service-grid">
      <service-card
        wx:for="{{serviceTypes}}"
        wx:key="key"
        type="{{item.key}}"
        data-type="{{item.key}}"
        bindtap="onServiceTap"
      />
    </view>
  </view>

  <!-- 推荐陪诊师 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">推荐陪诊师</text>
    </view>
    <view class="companion-list">
      <companion-card
        wx:for="{{companions}}"
        wx:key="id"
        companion="{{item}}"
        data-id="{{item.id}}"
        bindtap="onCompanionTap"
      />
    </view>
    <view class="empty-hint" wx:if="{{companions.length === 0}}">
      <text>暂无推荐陪诊师</text>
    </view>
  </view>
</view>

<patient-tab-bar active="home" />
