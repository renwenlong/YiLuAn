.patient-home {
  min-height: 100vh;
  background-color: #F5F5F5;
  padding: 24rpx;
  padding-bottom: 140rpx;
  box-sizing: border-box;
}

.section {
  margin-bottom: 40rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333333;
}

.section-hint {
  font-size: 24rpx;
  color: #999;
}

.section-clear {
  font-size: 24rpx;
  color: #1890FF;
}

/* 定位栏 */
.location-bar {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.location-icon {
  font-size: 28rpx;
}

.location-city {
  font-size: 26rpx;
  color: #1890FF;
}

/* 搜索框 */
.search-bar {
  margin-bottom: 20rpx;
}

.search-input {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 16rpx 28rpx;
  font-size: 28rpx;
  color: #333;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

/* 医院列表 */
.hospital-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.hospital-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.hospital-info {
  flex: 1;
  min-width: 0;
}

.hospital-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.hospital-meta {
  display: block;
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
}

.hospital-arrow {
  font-size: 28rpx;
  color: #CCCCCC;
  margin-left: 16rpx;
}

.hospital-card.active {
  border: 2rpx solid #1890FF;
  background: #E6F7FF;
}

.hospital-check {
  font-size: 32rpx;
  color: #1890FF;
  font-weight: 600;
  margin-left: 16rpx;
}

.service-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.companion-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.empty-hint {
  text-align: center;
  padding: 60rpx 0;
  color: #999999;
  font-size: 28rpx;
}

.loading-hint {
  text-align: center;
  padding: 40rpx 0;
  color: #1890FF;
  font-size: 28rpx;
}

.load-more {
  text-align: center;
  padding: 32rpx 0;
}

.load-more-text {
  display: inline-block;
  padding: 16rpx 48rpx;
  font-size: 28rpx;
  color: #1890FF;
  border: 1rpx solid #1890FF;
  border-radius: 32rpx;
}

.no-more-hint {
  text-align: center;
  padding: 32rpx 0;
  color: #CCCCCC;
  font-size: 24rpx;
}

/* 城市选择弹窗 */
.city-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.city-modal {
  width: 100%;
  max-height: 70vh;
  background: #FFFFFF;
  border-radius: 24rpx 24rpx 0 0;
  display: flex;
  flex-direction: column;
}

.city-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.city-modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.city-modal-close {
  font-size: 36rpx;
  color: #999999;
  padding: 0 8rpx;
}

.city-modal-body {
  padding: 16rpx 32rpx 48rpx;
  overflow-y: auto;
  max-height: 60vh;
}

.city-option {
  display: flex;
  align-items: center;
  padding: 28rpx 16rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.city-option:active {
  background: #F5F5F5;
}

.city-option.active {
  background: #E6F7FF;
}

.city-option-locate {
  background: #F0F5FF;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  border-bottom: none;
}

.city-option-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.city-option-text {
  font-size: 30rpx;
  color: #333333;
  flex: 1;
}

.city-option-hint {
  font-size: 26rpx;
  color: #1890FF;
}

.city-option-check {
  font-size: 32rpx;
  color: #1890FF;
  font-weight: 600;
}

.city-list-title {
  font-size: 26rpx;
  color: #999999;
  padding: 20rpx 0 8rpx;
}
