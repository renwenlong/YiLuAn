.patient-home {
  min-height: 100vh;
  background-color: #F5F5F5;
  padding: 24rpx;
  padding-bottom: 140rpx;
  box-sizing: border-box;
}

.section {
  margin-bottom: 40rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333333;
}

.service-grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.companion-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.empty-hint {
  text-align: center;
  padding: 60rpx 0;
  color: #999999;
  font-size: 28rpx;
}
