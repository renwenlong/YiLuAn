/* ============================================
 * Patient Home — Upgraded UI v2.0
 * ============================================ */

.patient-home {
  min-height: 100vh;
  background-color: var(--color-bg-page);
  padding: var(--spacing-md);
  padding-bottom: 140rpx;
  box-sizing: border-box;
}

/* ---- Search Hero Area ---- */
.search-hero {
  background: var(--gradient-hero);
  margin: calc(-1 * var(--spacing-md));
  margin-bottom: var(--spacing-lg);
  padding: var(--spacing-xl) var(--spacing-md) var(--spacing-lg);
  border-radius: 0 0 var(--radius-xl) var(--radius-xl);
}

/* ---- Section ---- */
.section {
  margin-bottom: var(--spacing-xl);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--spacing-md);
}

.section-title {
  font-size: var(--font-size-h1);
  font-weight: 600;
  color: var(--color-text-primary);
  line-height: var(--line-height-tight);
}

.section-hint {
  font-size: var(--font-size-caption);
  color: var(--color-text-hint);
}

.section-clear {
  font-size: var(--font-size-caption);
  color: var(--color-text-link);
  transition: opacity var(--duration-fast) var(--ease-in-out);
}

.section-clear:active {
  opacity: 0.7;
}

/* ---- Location Bar ---- */
.location-bar {
  display: flex;
  align-items: center;
  gap: var(--spacing-xs);
}

.location-icon {
  font-size: var(--font-size-body);
}

.location-city {
  font-size: var(--font-size-caption);
  color: var(--color-primary);
  font-weight: 500;
}

/* ---- Search Bar ---- */
.search-bar {
  margin-bottom: var(--spacing-md);
}

.search-input {
  background: var(--color-bg-card);
  border-radius: var(--radius-full);
  padding: var(--spacing-sm) var(--spacing-lg);
  font-size: var(--font-size-body);
  color: var(--color-text-primary);
  box-shadow: var(--shadow-sm), inset 0 1rpx 4rpx rgba(0, 0, 0, 0.03);
  transition: box-shadow var(--duration-normal) var(--ease-in-out),
              border-color var(--duration-normal) var(--ease-in-out);
  border: 2rpx solid transparent;
}

.search-input-focus {
  box-shadow: var(--shadow-md), inset 0 1rpx 4rpx rgba(0, 0, 0, 0.02);
  border-color: var(--color-border-focus);
}

/* ---- Hospital List ---- */
.hospital-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-sm);
}

.hospital-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: var(--spacing-md);
  box-shadow: var(--shadow-sm);
  transition: transform var(--duration-fast) var(--ease-in-out),
              box-shadow var(--duration-fast) var(--ease-in-out);
  border-left: 4rpx solid transparent;
}

.hospital-card:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-xs);
}

.hospital-card.active {
  border-left-color: var(--color-primary);
  background: var(--color-primary-light);
  box-shadow: var(--shadow-md);
}

.hospital-info {
  flex: 1;
  min-width: 0;
}

.hospital-name {
  display: block;
  font-size: var(--font-size-h2);
  font-weight: 600;
  color: var(--color-text-primary);
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
  line-height: var(--line-height-tight);
}

.hospital-meta {
  display: block;
  font-size: var(--font-size-caption);
  color: var(--color-text-hint);
  margin-top: var(--spacing-xs);
}

.hospital-arrow {
  font-size: var(--font-size-body);
  color: var(--color-text-disabled);
  margin-left: var(--spacing-sm);
  transition: transform var(--duration-fast) var(--ease-in-out);
}

.hospital-card:active .hospital-arrow {
  transform: translateX(4rpx);
}

.hospital-check {
  font-size: var(--font-size-h2);
  color: var(--color-primary);
  font-weight: 600;
  margin-left: var(--spacing-sm);
}

/* ---- Service Grid ---- */
.service-grid {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-sm);
}

/* ---- Companion List ---- */
.companion-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-sm);
}

/* ---- Empty & Loading Hints ---- */
.empty-hint {
  text-align: center;
  padding: var(--spacing-2xl) 0;
  color: var(--color-text-hint);
  font-size: var(--font-size-body);
  line-height: var(--line-height-relaxed);
}

.empty-hint-icon {
  display: block;
  font-size: 80rpx;
  opacity: 0.3;
  margin-bottom: var(--spacing-sm);
}

.loading-hint {
  text-align: center;
  padding: var(--spacing-lg) 0;
  color: var(--color-primary);
  font-size: var(--font-size-body);
  animation: pulse 1.5s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

/* ---- Load More ---- */
.load-more {
  text-align: center;
  padding: var(--spacing-lg) 0;
}

.load-more-text {
  display: inline-block;
  padding: var(--spacing-sm) var(--spacing-xl);
  font-size: var(--font-size-body);
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary);
  border-radius: var(--radius-full);
  background: var(--color-bg-card);
  transition: all var(--duration-fast) var(--ease-in-out);
}

.load-more-text:active {
  background: var(--color-primary-light);
  transform: scale(0.98);
}

.no-more-hint {
  text-align: center;
  padding: var(--spacing-lg) 0;
  color: var(--color-text-disabled);
  font-size: var(--font-size-caption);
}

/* ---- City Modal ---- */
.city-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--color-bg-mask);
  z-index: var(--z-modal);
  display: flex;
  align-items: flex-end;
}

.city-modal {
  width: 100%;
  max-height: 70vh;
  background: var(--color-bg-card);
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  display: flex;
  flex-direction: column;
  animation: slideUp var(--duration-normal) var(--ease-spring);
}

.city-modal-handle {
  width: 64rpx;
  height: 8rpx;
  background: var(--color-border);
  border-radius: var(--radius-full);
  margin: var(--spacing-sm) auto 0;
}

.city-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-lg);
  border-bottom: 1rpx solid var(--color-border-light);
}

.city-modal-title {
  font-size: var(--font-size-h2);
  font-weight: 600;
  color: var(--color-text-primary);
}

.city-modal-close {
  font-size: var(--font-size-h1);
  color: var(--color-text-hint);
  padding: 0 var(--spacing-xs);
  transition: color var(--duration-fast) var(--ease-in-out);
}

.city-modal-close:active {
  color: var(--color-text-secondary);
}

.city-modal-body {
  padding: var(--spacing-sm) var(--spacing-lg) var(--spacing-xl);
  overflow-y: auto;
  max-height: 60vh;
}

.city-option {
  display: flex;
  align-items: center;
  padding: var(--spacing-md) var(--spacing-sm);
  border-bottom: 1rpx solid var(--color-border-light);
  border-radius: var(--radius-md);
  transition: background var(--duration-fast) var(--ease-in-out);
}

.city-option:active {
  background: var(--color-bg-hover);
}

.city-option.active {
  background: var(--color-primary-light);
}

.city-option-locate {
  background: var(--color-primary-light);
  border-radius: var(--radius-md);
  margin-bottom: var(--spacing-sm);
  border-bottom: none;
}

.city-option-icon {
  font-size: var(--font-size-h2);
  margin-right: var(--spacing-sm);
}

.city-option-text {
  font-size: var(--font-size-h2);
  color: var(--color-text-primary);
  flex: 1;
}

.city-option-hint {
  font-size: var(--font-size-caption);
  color: var(--color-primary);
}

.city-option-check {
  font-size: var(--font-size-h2);
  color: var(--color-primary);
  font-weight: 600;
}

.city-list-title {
  font-size: var(--font-size-caption);
  color: var(--color-text-hint);
  padding: var(--spacing-md) 0 var(--spacing-xs);
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}
