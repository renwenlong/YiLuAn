.page-container {
  padding: 24rpx;
  padding-bottom: 120rpx;
}

/* Step Indicator */
.step-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx 0;
  margin-bottom: 32rpx;
}

.step-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.step-number {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background-color: #e0e0e0;
  color: #999;
  font-size: 28rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
}

.step-item.active .step-number {
  background-color: #1890FF;
  color: #fff;
}

.step-label {
  font-size: 24rpx;
  color: #999;
}

.step-item.active .step-label {
  color: #1890FF;
  font-weight: bold;
}

.step-line {
  width: 60rpx;
  height: 4rpx;
  background-color: #e0e0e0;
  margin: 0 12rpx;
  margin-bottom: 32rpx;
}

.step-line.active {
  background-color: #1890FF;
}

/* Step Content */
.step-content {
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 32rpx;
}

/* Service Type */
.service-type-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.service-type-btn {
  padding: 32rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 16rpx;
  background-color: #fff;
}

.service-type-btn.selected {
  border-color: #1890FF;
  background-color: #E6F7FF;
}

.service-type-main {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.service-type-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.service-type-btn.selected .service-type-name {
  color: #1890FF;
}

.service-type-price {
  font-size: 32rpx;
  font-weight: 700;
  color: #FF6B35;
}

/* Recent Hospitals */
.recent-hospitals {
  margin-bottom: 24rpx;
}

.recent-label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.recent-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.recent-tag {
  padding: 12rpx 28rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #333;
  background-color: #fff;
}

.recent-tag.selected {
  border-color: #1890FF;
  background-color: #E6F7FF;
  color: #1890FF;
}

/* Filter Bar */
.filter-form {
  margin-bottom: 24rpx;
}

.form-row {
  display: flex;
  gap: 24rpx;
}

.form-group-half {
  flex: 1;
}

.picker-value.placeholder {
  color: #bbb;
}

/* Search Bar — removed */

/* Hospital List */
.hospital-list {
  max-height: 600rpx;
  overflow-y: auto;
}

.hospital-item {
  padding: 24rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  background-color: #fff;
}

.hospital-item.selected {
  border-color: #1890FF;
  background-color: #E6F7FF;
}

.hospital-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.hospital-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.hospital-level {
  font-size: 22rpx;
  color: #FF6B35;
  border: 1rpx solid #FF6B35;
  border-radius: 6rpx;
  padding: 2rpx 10rpx;
  flex-shrink: 0;
}

.hospital-address {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.empty-tip {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* Form */
.form-group {
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.picker-value {
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 24rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  background-color: #fff;
}

.form-textarea {
  width: 100%;
  height: 200rpx;
  padding: 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  background-color: #fff;
}

/* Summary Card */
.summary-card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.summary-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.summary-row:last-child {
  border-bottom: none;
}

.summary-label {
  font-size: 28rpx;
  color: #666;
  flex-shrink: 0;
}

.summary-value {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
  text-align: right;
}

.summary-notes {
  max-width: 400rpx;
  word-break: break-all;
}

.summary-price-row {
  margin-top: 8rpx;
  padding-top: 28rpx;
  border-top: 2rpx solid #f0f0f0;
}

.summary-price {
  font-size: 40rpx;
  font-weight: 700;
  color: #FF6B35;
}

/* Step Actions */
.step-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 48rpx;
  padding-bottom: 40rpx;
}

.btn-primary {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  background: linear-gradient(135deg, #1890FF, #36CFC9);
  color: #fff;
  border-radius: 44rpx;
  font-weight: bold;
  padding: 0;
  border: none;
}

.btn-primary::after {
  border: none;
}

.btn-secondary {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  background-color: #f5f5f5;
  color: #666;
  border-radius: 44rpx;
  padding: 0;
  border: none;
}

.btn-secondary::after {
  border: none;
}
