.page-container {
  min-height: 100vh;
  background-color: #F5F5F5;
  padding: 24rpx;
  padding-bottom: 180rpx;
  box-sizing: border-box;
}

/* Info Section */
.info-section {
  margin-bottom: 32rpx;
}

.section-label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.section-header .section-label {
  margin-bottom: 0;
}

.change-btn {
  font-size: 26rpx;
  color: #1890FF;
}

/* Info Card */
.info-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.info-card.placeholder {
  opacity: 0.6;
}

.info-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

.placeholder-text {
  color: #999;
  font-weight: 400;
}

.info-price {
  font-size: 32rpx;
  font-weight: 700;
  color: #FF6B35;
}

/* Companion Info Card */
.companion-info-card {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.avatar-placeholder {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #1890FF, #36CFC9);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.avatar-placeholder.small {
  width: 64rpx;
  height: 64rpx;
}

.avatar-text {
  font-size: 32rpx;
  color: #FFFFFF;
  font-weight: 600;
}

.avatar-placeholder.small .avatar-text {
  font-size: 26rpx;
}

.companion-detail {
  flex: 1;
  min-width: 0;
}

.companion-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
}

.companion-meta {
  display: flex;
  gap: 24rpx;
}

.companion-meta .meta-item {
  font-size: 24rpx;
  color: #999;
}

/* Picker */
.picker-value {
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 24rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  background-color: #fff;
}

/* Textarea */
.form-textarea {
  width: 100%;
  height: 200rpx;
  padding: 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  background-color: #fff;
}

/* Submit Area */
.submit-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #FFFFFF;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  background: linear-gradient(135deg, #1890FF, #36CFC9);
  color: #fff;
  border-radius: 44rpx;
  font-weight: bold;
  padding: 0;
  border: none;
}

.submit-btn::after {
  border: none;
}

/* Modal */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.modal-content {
  width: 100%;
  max-height: 70vh;
  background: #FFFFFF;
  border-radius: 24rpx 24rpx 0 0;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.modal-close {
  font-size: 36rpx;
  color: #999999;
  padding: 0 8rpx;
}

.modal-body {
  padding: 16rpx 32rpx 48rpx;
  overflow-y: auto;
  max-height: 60vh;
}

/* Companion Option */
.companion-option {
  display: flex;
  align-items: center;
  padding: 24rpx 16rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.companion-option:active {
  background: #F5F5F5;
}

.companion-option.active {
  background: #E6F7FF;
}

.companion-option-info {
  flex: 1;
  min-width: 0;
}

.companion-option-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 6rpx;
}

.companion-option-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

.verified-badge {
  font-size: 20rpx;
  color: #1890FF;
  background: #E6F7FF;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
}

.companion-option-stats {
  display: flex;
  gap: 20rpx;
  margin-bottom: 8rpx;
}

.companion-option-stats .stat-item {
  font-size: 24rpx;
  color: #999;
}

.companion-option-bio {
  display: block;
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.companion-option-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.area-tag {
  font-size: 22rpx;
  color: #1890FF;
  background: #F0F5FF;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.companion-option-check {
  font-size: 32rpx;
  color: #1890FF;
  font-weight: 600;
  margin-left: 16rpx;
}

/* Hints */
.loading-hint {
  text-align: center;
  padding: 40rpx 0;
  color: #1890FF;
  font-size: 28rpx;
}

.empty-hint {
  text-align: center;
  padding: 60rpx 0;
  color: #999999;
  font-size: 28rpx;
}
