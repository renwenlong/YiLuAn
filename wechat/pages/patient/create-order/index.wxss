.page-container {
  padding: 24rpx;
  padding-bottom: 120rpx;
}

/* Step Indicator */
.step-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx 0;
  margin-bottom: 32rpx;
}

.step-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.step-number {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background-color: #e0e0e0;
  color: #999;
  font-size: 28rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
}

.step-item.active .step-number {
  background-color: #4CAF50;
  color: #fff;
}

.step-label {
  font-size: 24rpx;
  color: #999;
}

.step-item.active .step-label {
  color: #4CAF50;
  font-weight: bold;
}

.step-line {
  width: 60rpx;
  height: 4rpx;
  background-color: #e0e0e0;
  margin: 0 12rpx;
  margin-bottom: 32rpx;
}

.step-line.active {
  background-color: #4CAF50;
}

/* Step Content */
.step-content {
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 32rpx;
}

/* Service Type */
.service-type-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.service-type-btn {
  display: flex;
  flex-direction: column;
  padding: 32rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 16rpx;
  background-color: #fff;
}

.service-type-btn.selected {
  border-color: #4CAF50;
  background-color: #f0f9f0;
}

.service-type-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.service-type-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.service-type-desc {
  font-size: 26rpx;
  color: #666;
}

/* Search Bar */
.search-bar {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.search-input {
  flex: 1;
  height: 80rpx;
  padding: 0 24rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 28rpx;
  background-color: #fff;
}

.search-btn {
  width: 140rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  background-color: #4CAF50;
  color: #fff;
  border-radius: 12rpx;
  padding: 0;
}

/* Hospital List */
.hospital-list {
  max-height: 600rpx;
  overflow-y: auto;
}

.hospital-item {
  padding: 24rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  background-color: #fff;
}

.hospital-item.selected {
  border-color: #4CAF50;
  background-color: #f0f9f0;
}

.hospital-name {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.hospital-address {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.empty-tip {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* Form */
.form-group {
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.picker-value {
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 24rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  background-color: #fff;
}

.form-textarea {
  width: 100%;
  height: 200rpx;
  padding: 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  background-color: #fff;
}

/* Summary Card */
.summary-card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.summary-row {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.summary-row:last-child {
  border-bottom: none;
}

.summary-label {
  font-size: 28rpx;
  color: #666;
}

.summary-value {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}

/* Step Actions */
.step-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 48rpx;
  padding-bottom: 40rpx;
}

.btn-primary {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  background-color: #4CAF50;
  color: #fff;
  border-radius: 16rpx;
  font-weight: bold;
  padding: 0;
}

.btn-secondary {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  background-color: #f5f5f5;
  color: #666;
  border-radius: 16rpx;
  padding: 0;
}
