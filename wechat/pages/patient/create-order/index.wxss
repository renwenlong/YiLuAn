/* ============================================
 * Create Order — Upgraded UI v2.0
 * ============================================ */

.page-container {
  min-height: 100vh;
  background-color: var(--color-bg-page);
  padding: var(--spacing-md);
  padding-bottom: 180rpx;
  box-sizing: border-box;
}

/* ---- Info Section ---- */
.info-section {
  margin-bottom: var(--spacing-lg);
}

.section-label {
  display: block;
  font-size: var(--font-size-body);
  color: var(--color-text-secondary);
  margin-bottom: var(--spacing-sm);
  font-weight: 500;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--spacing-sm);
}

.section-header .section-label {
  margin-bottom: 0;
}

.change-btn {
  font-size: var(--font-size-caption);
  color: var(--color-text-link);
  transition: opacity var(--duration-fast) var(--ease-in-out);
}

.change-btn:active {
  opacity: 0.7;
}

/* ---- Info Card ---- */
.info-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: var(--spacing-lg) var(--spacing-md);
  box-shadow: var(--shadow-sm);
  border-left: 4rpx solid var(--color-primary);
  transition: transform var(--duration-fast) var(--ease-in-out),
              box-shadow var(--duration-fast) var(--ease-in-out);
}

.info-card:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-xs);
}

.info-card.placeholder {
  opacity: 0.6;
  border-left-color: var(--color-border);
}

.info-name {
  font-size: var(--font-size-h2);
  font-weight: 600;
  color: var(--color-text-primary);
}

.placeholder-text {
  color: var(--color-text-hint);
  font-weight: 400;
}

.info-price {
  font-size: var(--font-size-h2);
  font-weight: 700;
  color: var(--color-accent);
  background: rgba(255, 122, 69, 0.08);
  padding: var(--spacing-xs) var(--spacing-sm);
  border-radius: var(--radius-full);
}

/* ---- Companion Info Card ---- */
.companion-info-card {
  display: flex;
  align-items: center;
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: var(--spacing-md);
  box-shadow: var(--shadow-sm);
  border-left: 4rpx solid var(--color-primary);
  transition: transform var(--duration-fast) var(--ease-in-out);
}

.companion-info-card:active {
  transform: scale(0.98);
}

.avatar-placeholder {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: var(--gradient-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: var(--spacing-md);
  flex-shrink: 0;
  box-shadow: var(--shadow-primary);
}

.avatar-placeholder.small {
  width: 64rpx;
  height: 64rpx;
  box-shadow: none;
}

.avatar-text {
  font-size: var(--font-size-h2);
  color: var(--color-text-white);
  font-weight: 600;
}

.avatar-placeholder.small .avatar-text {
  font-size: var(--font-size-caption);
}

.companion-detail {
  flex: 1;
  min-width: 0;
}

.companion-name {
  display: block;
  font-size: var(--font-size-h2);
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: var(--spacing-xs);
}

.companion-meta {
  display: flex;
  gap: var(--spacing-md);
}

.companion-meta .meta-item {
  font-size: var(--font-size-caption);
  color: var(--color-text-hint);
}

/* ---- Picker ---- */
.picker-value {
  height: 88rpx;
  line-height: 88rpx;
  padding: 0 var(--spacing-md);
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-md);
  font-size: var(--font-size-body);
  color: var(--color-text-primary);
  background: var(--color-bg-input);
  display: flex;
  align-items: center;
  justify-content: space-between;
  transition: border-color var(--duration-fast) var(--ease-in-out),
              box-shadow var(--duration-fast) var(--ease-in-out);
}

.picker-value:active {
  border-color: var(--color-border-focus);
  box-shadow: 0 0 0 4rpx rgba(24, 144, 255, 0.1);
}

.picker-arrow {
  font-size: var(--font-size-caption);
  color: var(--color-text-hint);
  transition: transform var(--duration-fast) var(--ease-in-out);
}

/* ---- Textarea ---- */
.form-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: var(--spacing-md);
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-md);
  font-size: var(--font-size-body);
  box-sizing: border-box;
  background: var(--color-bg-input);
  color: var(--color-text-primary);
  line-height: var(--line-height-relaxed);
  transition: border-color var(--duration-fast) var(--ease-in-out),
              box-shadow var(--duration-fast) var(--ease-in-out);
}

.form-textarea-focus {
  border-color: var(--color-border-focus);
  box-shadow: 0 0 0 4rpx rgba(24, 144, 255, 0.1);
  background: var(--color-bg-card);
}

.char-count {
  text-align: right;
  font-size: var(--font-size-small);
  color: var(--color-text-disabled);
  margin-top: var(--spacing-xs);
}

.char-count.near-limit {
  color: var(--color-warning);
}

.char-count.at-limit {
  color: var(--color-danger);
}

/* ---- Submit Area ---- */
.submit-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: var(--spacing-md) var(--spacing-lg);
  padding-bottom: calc(var(--spacing-md) + env(safe-area-inset-bottom));
  background: var(--color-bg-card);
  box-shadow: 0 -2rpx 16rpx rgba(0, 0, 0, 0.06);
  z-index: var(--z-fixed);
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-size-h2);
  background: var(--gradient-primary);
  color: var(--color-text-white);
  border-radius: var(--radius-full);
  font-weight: 600;
  padding: 0;
  border: none;
  box-shadow: var(--shadow-primary);
  transition: opacity var(--duration-fast) var(--ease-in-out),
              transform var(--duration-fast) var(--ease-in-out);
}

.submit-btn::after {
  border: none;
}

.submit-btn:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.submit-btn[disabled] {
  opacity: 0.4;
  box-shadow: none;
}

/* ---- Modal ---- */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--color-bg-mask);
  z-index: var(--z-modal);
  display: flex;
  align-items: flex-end;
}

.modal-content {
  width: 100%;
  max-height: 70vh;
  background: var(--color-bg-card);
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  display: flex;
  flex-direction: column;
  animation: slideUp var(--duration-normal) var(--ease-spring);
}

.modal-handle {
  width: 64rpx;
  height: 8rpx;
  background: var(--color-border);
  border-radius: var(--radius-full);
  margin: var(--spacing-sm) auto 0;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-lg);
  border-bottom: 1rpx solid var(--color-border-light);
}

.modal-title {
  font-size: var(--font-size-h2);
  font-weight: 600;
  color: var(--color-text-primary);
}

.modal-close {
  font-size: var(--font-size-h1);
  color: var(--color-text-hint);
  padding: 0 var(--spacing-xs);
  transition: color var(--duration-fast) var(--ease-in-out);
}

.modal-close:active {
  color: var(--color-text-secondary);
}

.modal-body {
  padding: var(--spacing-sm) var(--spacing-lg) var(--spacing-xl);
  overflow-y: auto;
  max-height: 60vh;
}

/* ---- Companion Option ---- */
.companion-option {
  display: flex;
  align-items: center;
  padding: var(--spacing-md) var(--spacing-sm);
  border-bottom: 1rpx solid var(--color-border-light);
  border-radius: var(--radius-md);
  transition: background var(--duration-fast) var(--ease-in-out);
}

.companion-option:active {
  background: var(--color-bg-hover);
}

.companion-option.active {
  background: var(--color-primary-light);
}

.companion-option-info {
  flex: 1;
  min-width: 0;
}

.companion-option-header {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  margin-bottom: var(--spacing-xs);
}

.companion-option-name {
  font-size: var(--font-size-h2);
  font-weight: 600;
  color: var(--color-text-primary);
}

.verified-badge {
  font-size: var(--font-size-small);
  color: var(--color-primary);
  background: var(--color-primary-light);
  padding: var(--spacing-2xs) var(--spacing-sm);
  border-radius: var(--radius-full);
  font-weight: 500;
}

.companion-option-stats {
  display: flex;
  gap: var(--spacing-md);
  margin-bottom: var(--spacing-xs);
}

.companion-option-stats .stat-item {
  font-size: var(--font-size-caption);
  color: var(--color-text-hint);
}

.companion-option-bio {
  display: block;
  font-size: var(--font-size-caption);
  color: var(--color-text-secondary);
  margin-bottom: var(--spacing-xs);
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  line-height: var(--line-height-relaxed);
}

.companion-option-tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacing-xs);
}

.area-tag {
  font-size: var(--font-size-small);
  color: var(--color-primary);
  background: var(--color-primary-light);
  padding: var(--spacing-2xs) var(--spacing-sm);
  border-radius: var(--radius-sm);
}

.companion-option-check {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 2rpx solid var(--color-border);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: var(--spacing-sm);
  flex-shrink: 0;
  transition: all var(--duration-fast) var(--ease-in-out);
}

.companion-option.active .companion-option-check {
  background: var(--gradient-primary);
  border-color: var(--color-primary);
  color: var(--color-text-white);
  font-size: var(--font-size-caption);
}

/* ---- Hints ---- */
.loading-hint {
  text-align: center;
  padding: var(--spacing-lg) 0;
  color: var(--color-primary);
  font-size: var(--font-size-body);
  animation: pulse 1.5s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.empty-hint {
  text-align: center;
  padding: var(--spacing-2xl) 0;
  color: var(--color-text-hint);
  font-size: var(--font-size-body);
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}
