<view class="page-container">
  <!-- 已选服务 -->
  <view class="info-section">
    <text class="section-label">服务类型</text>
    <view class="info-card">
      <text class="info-name">{{serviceTypeName}}</text>
      <text class="info-price">¥{{servicePrice}}</text>
    </view>
  </view>

  <!-- 已选医院 -->
  <view class="info-section">
    <text class="section-label">就诊医院</text>
    <view class="info-card">
      <text class="info-name">{{hospitalName}}</text>
    </view>
  </view>

  <!-- 指定陪诊师 -->
  <view class="info-section">
    <view class="section-header">
      <text class="section-label">指定陪诊师</text>
      <text class="change-btn" bindtap="onChangeCompanion">重新选择</text>
    </view>
    <view class="companion-info-card" wx:if="{{companion}}">
      <view class="avatar-placeholder">
        <text class="avatar-text">{{companion.name[0]}}</text>
      </view>
      <view class="companion-detail">
        <text class="companion-name">{{companion.name}}</text>
        <view class="companion-meta">
          <text class="meta-item">★ {{companion.rating}}</text>
          <text class="meta-item">已完成 {{companion.completed_orders}} 单</text>
        </view>
      </view>
    </view>
    <view class="info-card placeholder" wx:else>
      <text class="info-name placeholder-text">加载中...</text>
    </view>
  </view>

  <!-- 预约日期 -->
  <view class="info-section">
    <text class="section-label">预约日期</text>
    <picker mode="date" value="{{date}}" bindchange="onDateChange">
      <view class="picker-value">{{date || '请选择日期'}}</view>
    </picker>
  </view>

  <!-- 预约时间 -->
  <view class="info-section">
    <text class="section-label">预约时间</text>
    <picker mode="time" value="{{time}}" bindchange="onTimeChange">
      <view class="picker-value">{{time || '请选择时间'}}</view>
    </picker>
  </view>

  <!-- 备注 -->
  <view class="info-section">
    <text class="section-label">备注（可选）</text>
    <textarea class="form-textarea" placeholder="请描述您的需求，如科室、症状等" value="{{notes}}" bindinput="onNotesInput" maxlength="200" />
  </view>

  <!-- 提交按钮 -->
  <view class="submit-area">
    <button class="submit-btn" bindtap="onSubmit" loading="{{loading}}">确认下单 ¥{{servicePrice}}</button>
  </view>
</view>

<!-- 陪诊师选择弹窗 -->
<view class="modal-mask" wx:if="{{showCompanionPicker}}" bindtap="onCloseCompanionPicker">
  <view class="modal-content" catchtap>
    <view class="modal-header">
      <text class="modal-title">选择陪诊师</text>
      <text class="modal-close" bindtap="onCloseCompanionPicker">✕</text>
    </view>
    <view class="modal-body">
      <view class="loading-hint" wx:if="{{loadingCompanions}}">
        <text>加载中...</text>
      </view>
      <view
        class="companion-option {{companionId === item.id ? 'active' : ''}}"
        wx:for="{{companionList}}"
        wx:key="id"
        data-id="{{item.id}}"
        bindtap="onSelectCompanion"
      >
        <view class="avatar-placeholder small">
          <text class="avatar-text">{{item.name[0]}}</text>
        </view>
        <view class="companion-option-info">
          <view class="companion-option-header">
            <text class="companion-option-name">{{item.name}}</text>
            <text class="verified-badge" wx:if="{{item.verified}}">已认证</text>
          </view>
          <view class="companion-option-stats">
            <text class="stat-item">★ {{item.rating}}</text>
            <text class="stat-item">已完成 {{item.completed_orders}} 单</text>
          </view>
          <text class="companion-option-bio" wx:if="{{item.bio}}">{{item.bio}}</text>
          <view class="companion-option-tags" wx:if="{{item.service_areas.length > 0}}">
            <text class="area-tag" wx:for="{{item.service_areas}}" wx:for-item="area" wx:key="*this">{{area}}</text>
          </view>
        </view>
        <text class="companion-option-check" wx:if="{{companionId === item.id}}">✓</text>
      </view>
      <view class="empty-hint" wx:if="{{!loadingCompanions && companionList.length === 0}}">
        <text>暂无匹配的陪诊师</text>
      </view>
    </view>
  </view>
</view>
