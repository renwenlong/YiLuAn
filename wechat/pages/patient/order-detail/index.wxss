/* ============================================
 * Patient Order Detail — Upgraded UI v2.0
 * ============================================ */

/* A21-05: action-bar 改为跟随内容 + safe-area padding，page 不再需要为 fixed bar 预留底部空间 */
.page-container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
}

/* ---- Status Header with Gradients ---- */
.status-header {
  padding: var(--spacing-xl) var(--spacing-lg);
  color: var(--color-text-white);
  text-align: center;
  position: relative;
  overflow: hidden;
}

.status-header::after {
  content: '';
  position: absolute;
  right: -40rpx;
  top: -40rpx;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
}

.status-header::before {
  content: '';
  position: absolute;
  left: -20rpx;
  bottom: -60rpx;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.05);
}

.status-header.status-created {
  background: linear-gradient(135deg, #FF9800 0%, #FFB74D 100%);
}

.status-header.status-accepted {
  background: linear-gradient(135deg, #1890FF 0%, #69C0FF 100%);
}

.status-header.status-in_progress {
  background: linear-gradient(135deg, #52C41A 0%, #95DE64 100%);
}

.status-header.status-completed {
  background: linear-gradient(135deg, #8C8C8C 0%, #BFBFBF 100%);
}

.status-header.status-cancelled {
  background: linear-gradient(135deg, #FF4D4F 0%, #FF7875 100%);
}

.status-header.status-rejected_by_companion {
  background: linear-gradient(135deg, #FF4D4F 0%, #FF7875 100%);
}

.status-header.status-expired {
  background: linear-gradient(135deg, #8C8C8C 0%, #BFBFBF 100%);
}

.status-subtitle {
  font-size: var(--font-size-caption);
  opacity: 0.85;
  margin-top: var(--spacing-xs);
  position: relative;
  z-index: 1;
}

.status-icon {
  font-size: 56rpx;
  margin-bottom: var(--spacing-sm);
  display: block;
}

.status-text {
  font-size: var(--font-size-h1);
  font-weight: 700;
  position: relative;
  z-index: 1;
}

.status-desc {
  font-size: var(--font-size-caption);
  opacity: 0.85;
  margin-top: var(--spacing-xs);
  position: relative;
  z-index: 1;
}

/* ---- Detail Section ---- */
.detail-section {
  margin: var(--spacing-md);
  padding: var(--spacing-lg);
  background-color: var(--color-bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
}

.section-title {
  font-size: var(--font-size-h2);
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: var(--spacing-md);
  padding-bottom: var(--spacing-sm);
  border-bottom: 1rpx solid var(--color-border-light);
  line-height: var(--line-height-tight);
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: var(--spacing-sm) 0;
}

.info-label {
  font-size: var(--font-size-body);
  color: var(--color-text-hint);
  flex-shrink: 0;
  margin-right: var(--spacing-md);
}

.info-value {
  font-size: var(--font-size-body);
  color: var(--color-text-primary);
  text-align: right;
  word-break: break-all;
}

/* P-02: 金额字号统一 (brand orange + bold + 36rpx，对齐 .polish-amount) */
.info-value.price {
  color: var(--color-accent);
  font-weight: 700;
  font-size: 36rpx;
  font-variant-numeric: tabular-nums;
}

.info-value.payment-unpaid {
  color: var(--color-danger);
  font-weight: 600;
}

.info-value.payment-paid {
  color: var(--color-success);
  font-weight: 600;
}

.info-value.payment-refunded {
  color: var(--color-warning);
  font-weight: 600;
}

/* ---- Companion Card ---- */
.companion-card {
  display: flex;
  align-items: center;
  gap: var(--spacing-md);
}

.companion-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  flex-shrink: 0;
  box-shadow: var(--shadow-sm);
}

.companion-info {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-xs);
}

.companion-name {
  font-size: var(--font-size-h2);
  font-weight: 600;
  color: var(--color-text-primary);
}

.companion-phone {
  font-size: var(--font-size-caption);
  color: var(--color-primary);
  font-weight: 500;
}

/* ---- Timeline ---- */
.timeline {
  padding-left: var(--spacing-sm);
}

.timeline-item {
  display: flex;
  align-items: flex-start;
  gap: var(--spacing-md);
  padding-bottom: var(--spacing-lg);
  position: relative;
}

.timeline-item:not(:last-child)::after {
  content: '';
  position: absolute;
  left: 13rpx;
  top: 36rpx;
  bottom: 0;
  width: 3rpx;
  background-color: var(--color-border);
  border-radius: var(--radius-full);
}

.timeline-item.active:not(:last-child)::after {
  background: var(--gradient-primary);
}

.timeline-dot {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  background-color: var(--color-border);
  flex-shrink: 0;
  margin-top: 2rpx;
  transition: all var(--duration-normal) var(--ease-in-out);
}

.timeline-item.active .timeline-dot {
  background: var(--gradient-primary);
  box-shadow: 0 0 0 6rpx rgba(24, 144, 255, 0.15);
}

.timeline-item.active:first-child .timeline-dot {
  box-shadow: 0 0 0 8rpx rgba(24, 144, 255, 0.2);
}

.timeline-content {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-2xs);
  flex: 1;
}

.timeline-title {
  font-size: var(--font-size-body);
  color: var(--color-text-primary);
  line-height: var(--line-height-tight);
}

.timeline-item.active .timeline-title {
  font-weight: 600;
  color: var(--color-primary);
}

.timeline-time {
  font-size: var(--font-size-caption);
  color: var(--color-text-hint);
}

/* ---- Review Card ---- */
.review-card {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-sm);
  background: rgba(255, 122, 69, 0.04);
  border-radius: var(--radius-md);
  padding: var(--spacing-md);
  position: relative;
}

.review-card::before {
  content: '\201C';
  position: absolute;
  top: var(--spacing-xs);
  left: var(--spacing-sm);
  font-size: 64rpx;
  color: var(--color-accent);
  opacity: 0.15;
  line-height: 1;
  font-family: Georgia, serif;
}

.review-content {
  font-size: var(--font-size-body);
  color: var(--color-text-secondary);
  line-height: var(--line-height-relaxed);
  padding-top: var(--spacing-sm);
}

/* ---- Action Bar ---- */
/*
 * A21-05 fix: 原 position:fixed + 父容器固定 padding-bottom 在 iPhone SE 上会出现 2rpx ~ 2px 错位
 * （状态栏/safe-area 计算误差）。改为 sticky + flex 末端，让按钮跟随文档流，并通过
 * env(safe-area-inset-bottom) 兜底所有 iOS 机型的底部安全区。
 */
.action-bar {
  position: sticky;
  bottom: 0;
  left: 0;
  right: 0;
  margin-top: auto; /* flex 列末端：内容不足一屏时仍贴底 */
  display: flex;
  gap: var(--spacing-sm);
  padding: var(--spacing-md) var(--spacing-lg);
  background-color: var(--color-bg-card);
  box-shadow: 0 -2rpx 16rpx rgba(0, 0, 0, 0.06);
  padding-bottom: calc(var(--spacing-md) + env(safe-area-inset-bottom));
  z-index: var(--z-fixed);
}

.btn-primary {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  font-size: var(--font-size-h2);
  background: var(--gradient-primary);
  color: var(--color-text-white);
  border-radius: var(--radius-lg);
  font-weight: 600;
  padding: 0;
  border: none;
  box-shadow: var(--shadow-primary);
  transition: opacity var(--duration-fast) var(--ease-in-out),
              transform var(--duration-fast) var(--ease-in-out);
}

.btn-primary::after {
  border: none;
}

.btn-primary:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.btn-secondary {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  font-size: var(--font-size-h2);
  background: var(--color-bg-page);
  color: var(--color-text-secondary);
  border-radius: var(--radius-lg);
  padding: 0;
  border: none;
  transition: background var(--duration-fast) var(--ease-in-out),
              transform var(--duration-fast) var(--ease-in-out);
}

.btn-secondary::after {
  border: none;
}

.btn-secondary:active {
  background: var(--color-border-light);
  transform: scale(0.98);
}

.btn-danger {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  font-size: var(--font-size-h2);
  background: transparent;
  color: var(--color-danger);
  border: 2rpx solid var(--color-danger);
  border-radius: var(--radius-lg);
  padding: 0;
  transition: all var(--duration-fast) var(--ease-in-out);
}

.btn-danger::after {
  border: none;
}

.btn-danger:active {
  background: var(--color-danger-light);
  transform: scale(0.98);
}

/* D-020 \u4f34\u884c\uff1a\u5012\u8ba1\u65f6 <30 \u5206\u949f\u53d8\u7ea2\u63d0\u9192 */
.countdown-text { font-weight: 600; }
.countdown-urgent {
  color: #e53935;
  animation: countdown-pulse 1.2s ease-in-out infinite;
}
@keyframes countdown-pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.55; }
}

 
/* [F-03] Emergency call FAB + modal */
.emergency-fab {
  position: fixed;
  top: 120rpx;
  right: 20rpx;
  width: 140rpx;
  height: 140rpx;
  border-radius: 70rpx;
  background: #e53935;
  color: #fff;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(229, 57, 53, 0.5);
  z-index: 50;
}
.emergency-icon { font-size: 48rpx; line-height: 1; }
.emergency-label { font-size: 22rpx; margin-top: 4rpx; color: #fff; }
.em-mask {
  position: fixed; left: 0; right: 0; top: 0; bottom: 0;
  background: rgba(0,0,0,0.5); z-index: 100;
}
.em-modal {
  position: fixed; left: 40rpx; right: 40rpx; top: 25%;
  background: #fff; border-radius: 16rpx; padding: 32rpx;
  z-index: 101;
}
.em-title { font-size: 36rpx; font-weight: bold; color: #e53935; text-align: center; }
.em-hint { font-size: 26rpx; color: #888; text-align: center; margin-top: 8rpx; }
.em-list { display: flex; flex-direction: column; gap: 16rpx; margin-top: 24rpx; }
.em-item {
  border: 2rpx solid #f0f0f0; border-radius: 12rpx;
  padding: 24rpx; background: #fafafa;
}
.em-item-name { font-size: 30rpx; color: #333; font-weight: 500; }
.em-rel { font-size: 24rpx; color: #888; margin-left: 12rpx; font-weight: normal; }
.em-item-phone { font-size: 28rpx; color: #1890FF; margin-top: 6rpx; }
.em-hotline { border-color: #ffd6d6; background: #fff5f5; }
.em-hotline .em-item-phone { color: #e53935; }
.em-empty { text-align: center; padding: 24rpx 0; color: #888; font-size: 26rpx; }
.em-link { color: #1890FF; margin-left: 12rpx; }
.em-cancel {
  margin-top: 24rpx; background: #f0f0f0; color: #333; border-radius: 12rpx;
}
