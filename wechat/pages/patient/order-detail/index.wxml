<loading-overlay wx:if="{{loading}}" />

<view class="page-container" wx:if="{{order}}">
  <!-- [F-03] Emergency button (in_progress only) -->
  <view
    class="emergency-fab"
    wx:if="{{order.status === 'in_progress'}}"
    bindtap="onEmergencyTap"
  >
    <text class="emergency-icon">⚠️</text>
    <text class="emergency-label">紧急呼叫</text>
  </view>

  <!-- Emergency modal -->
  <view class="em-mask" wx:if="{{showEmergency}}" bindtap="onEmergencyClose" />
  <view class="em-modal" wx:if="{{showEmergency}}">
    <view class="em-title">紧急呼叫</view>
    <view class="em-hint">选择要拨打的联系人</view>
    <view class="em-list">
      <view
        class="em-item"
        wx:for="{{emergencyContacts}}"
        wx:key="id"
        data-id="{{item.id}}"
        bindtap="onCallContact"
      >
        <view class="em-item-name">{{item.name}} <text class="em-rel">{{item.relationship}}</text></view>
        <view class="em-item-phone">{{item.phone}}</view>
      </view>
      <view class="em-empty" wx:if="{{emergencyContacts.length === 0}}">
        <text>未设置紧急联系人</text>
        <text class="em-link" bindtap="onManageContacts">去添加</text>
      </view>
      <view class="em-item em-hotline" bindtap="onCallHotline">
        <view class="em-item-name">平台客服热线</view>
        <view class="em-item-phone">{{emergencyHotline || '加载中...'}}</view>
      </view>
    </view>
    <button class="em-cancel" bindtap="onEmergencyClose">取消</button>
  </view>
  <!-- Status Header -->
  <view class="status-header status-{{order.status}}">
    <view class="status-header-decor"></view>
    <text class="status-text">{{statusList[order.status].label || order.status}}</text>
    <text class="status-subtitle" wx:if="{{order.status === 'created' && order.payment_status === 'unpaid'}}">请尽快完成支付</text>
    <text class="status-subtitle" wx:elif="{{order.status === 'created' && countdown}}">距订单自动取消还剩 <text class="countdown-text {{countdownUrgent ? 'countdown-urgent' : ''}}">{{countdown}}</text></text>
    <text class="status-subtitle" wx:elif="{{order.status === 'created'}}">等待陪诊师接单</text>
    <text class="status-subtitle" wx:elif="{{order.status === 'accepted'}}">陪诊师已接单，即将为您服务</text>
    <text class="status-subtitle" wx:elif="{{order.status === 'in_progress'}}">服务进行中，请保持联系</text>
    <text class="status-subtitle" wx:elif="{{order.status === 'completed'}}">服务已完成</text>
    <text class="status-subtitle" wx:elif="{{order.status === 'rejected_by_companion'}}">陪诊师暂时无法为您服务，建议重新预约</text>
    <text class="status-subtitle" wx:elif="{{order.status === 'expired'}}">订单因超时未接单已自动取消，款项将原路退回</text>
    <text class="status-subtitle" wx:elif="{{order.status === 'cancelled_by_patient' || order.status === 'cancelled_by_companion'}}">订单已取消</text>
  </view>

  <!-- Order Info -->
  <view class="detail-section">
    <view class="section-title">订单信息</view>
    <view class="info-row">
      <text class="info-label">订单编号</text>
      <text class="info-value">{{order.order_number}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">服务类型</text>
      <text class="info-value">{{serviceLabel}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">医院</text>
      <text class="info-value">{{order.hospital_name}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">预约时间</text>
      <text class="info-value">{{order.appointment_date}} {{order.appointment_time}}</text>
    </view>
    <view class="info-row" wx:if="{{order.formattedPrice}}">
      <text class="info-label">费用</text>
      <text class="info-value price">{{order.formattedPrice}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">支付状态</text>
      <text class="info-value payment-{{paymentStatusClass}}">{{paymentStatusLabel}}</text>
    </view>
    <view class="info-row" wx:if="{{order.description}}">
      <text class="info-label">备注</text>
      <text class="info-value">{{order.description}}</text>
    </view>
  </view>

  <!-- Companion Info -->
  <view class="detail-section" wx:if="{{order.companion_name}}">
    <view class="section-title">陪诊师信息</view>
    <view class="info-row">
      <text class="info-label">陪诊师</text>
      <text class="info-value">{{order.companion_name}}</text>
    </view>
  </view>

  <!-- Status Timeline -->
  <view class="detail-section">
    <view class="section-title">订单进度</view>
    <view class="timeline">
      <view class="timeline-item {{order.timeline && index <= order.timelineIndex ? 'active' : ''}}" wx:for="{{order.timeline}}" wx:key="time">
        <view class="timeline-dot"></view>
        <view class="timeline-content">
          <text class="timeline-title">{{item.title}}</text>
          <text class="timeline-time">{{item.time}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Review Section (if completed with review) -->
  <view class="detail-section" wx:if="{{order.review}}">
    <view class="section-title">评价</view>
    <view class="review-card">
      <rating-stars value="{{order.review.rating}}" readonly="{{true}}" />
      <text class="review-content">{{order.review.content}}</text>
    </view>
  </view>

  <!-- Action Buttons -->
  <view class="action-bar">
    <!-- Created & unpaid: pay + cancel -->
    <block wx:if="{{order.status === 'created' && order.payment_status === 'unpaid'}}">
      <button class="btn-primary" bindtap="onPay">立即支付 {{order.formattedPrice}}</button>
      <button class="btn-danger" bindtap="onCancel">取消订单</button>
    </block>

    <!-- Created & paid: cancel only -->
    <block wx:if="{{order.status === 'created' && order.payment_status === 'paid'}}">
      <button class="btn-danger" bindtap="onCancel">取消订单</button>
    </block>

    <!-- Accepted / In Progress: can chat + cancel -->
    <block wx:if="{{order.status === 'accepted'}}">
      <button class="btn-primary" bindtap="onConfirmStart">确认开始服务</button>
      <button class="btn-secondary" bindtap="onChat">联系陪诊师</button>
      <button class="btn-danger" bindtap="onCancel">取消订单</button>
    </block>
    <block wx:if="{{order.status === 'in_progress'}}">
      <button class="btn-primary" bindtap="onChat">联系陪诊师</button>
      <button class="btn-danger" bindtap="onCancelInProgress">取消订单</button>
    </block>

    <!-- Completed without review: can review -->
    <block wx:if="{{order.status === 'completed' && !order.review}}">
      <button class="btn-primary" bindtap="onReview">写评价</button>
      <button class="btn-secondary" bindtap="onChat">联系陪诊师</button>
    </block>

    <!-- Rejected / Expired: reorder -->
    <block wx:if="{{order.status === 'rejected_by_companion' || order.status === 'expired'}}">
      <button class="btn-primary" bindtap="onReorder">重新下单</button>
    </block>
  </view>
</view>
