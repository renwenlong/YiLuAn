.notification-page {
  min-height: 100vh;
  background-color: var(--color-bg-page);
}

.header-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  background-color: var(--color-bg-card);
  border-bottom: 1rpx solid var(--color-border-light);
}

.unread-text {
  font-size: 28rpx;
  color: var(--color-danger);
}

.mark-all-btn {
  font-size: 28rpx;
  color: var(--color-primary);
}

.notification-list {
  background-color: var(--color-bg-card);
}

.notification-item {
  display: flex;
  align-items: flex-start;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid var(--color-border-light);
}

.notification-item.read {
  opacity: 0.6;
}

.notification-item:active {
  background-color: var(--color-bg-page);
}

.notif-icon {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
  padding-top: 6rpx;
}

.icon-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background-color: var(--color-danger);
}

.notif-content {
  flex: 1;
  min-width: 0;
}

.notif-title {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--color-text-primary);
  margin-bottom: 8rpx;
}

.notif-body {
  font-size: 26rpx;
  color: var(--color-text-hint);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.empty-text {
  font-size: 30rpx;
  color: var(--color-text-hint);
}

.loading-state {
  display: flex;
  justify-content: center;
  padding: 40rpx;
  color: var(--color-text-hint);
  font-size: 26rpx;
}
