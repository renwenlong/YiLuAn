/* Notification Page — Upgraded UI/UX */

.notification-page {
  min-height: 100vh;
  background-color: var(--color-bg-page);
}

.header-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background-color: var(--color-bg-card);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  position: sticky;
  top: 0;
  z-index: var(--z-sticky, 10);
}

.unread-text {
  font-size: 26rpx;
  color: var(--color-text-white);
  background-color: var(--color-danger);
  padding: 4rpx 16rpx;
  border-radius: var(--radius-full, 999rpx);
  font-weight: 500;
  line-height: 1.5;
}

.mark-all-btn {
  font-size: 28rpx;
  color: var(--color-primary);
  text-decoration: underline;
  text-underline-offset: 4rpx;
}

.notification-list {
  padding: 16rpx 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.notification-item {
  display: flex;
  align-items: flex-start;
  padding: 28rpx 24rpx;
  background-color: var(--color-bg-card);
  border-radius: var(--radius-lg, 16rpx);
  box-shadow: var(--shadow-card, 0 2rpx 8rpx rgba(0, 0, 0, 0.04));
  border-left: 6rpx solid var(--color-primary);
  transition: background-color var(--duration-fast, 0.2s);
}

.notification-item.read {
  border-left-color: transparent;
}

.notification-item.read .notif-title {
  color: var(--color-text-hint);
  font-weight: 400;
}

.notification-item.read .notif-body {
  color: var(--color-text-disabled, #C4C4C4);
}

.notification-item.read .icon-dot {
  visibility: hidden;
}

.notification-item:active {
  background-color: var(--color-bg-page);
}

.notif-icon {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
  padding-top: 6rpx;
}

.icon-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background-color: var(--color-primary);
  box-shadow: 0 0 0 4rpx rgba(24, 144, 255, 0.15);
}

.notif-content {
  flex: 1;
  min-width: 0;
}

.notif-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 8rpx;
}

.notif-body {
  font-size: 26rpx;
  color: var(--color-text-hint);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.empty-icon {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background-color: var(--color-bg-input, #F7F8FA);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.empty-icon text {
  font-size: 64rpx;
  opacity: 0.4;
}

.empty-text {
  font-size: 30rpx;
  color: var(--color-text-hint);
}

.loading-state {
  display: flex;
  justify-content: center;
  padding: 40rpx;
  color: var(--color-text-hint);
  font-size: 26rpx;
}
