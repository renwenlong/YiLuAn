.login-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  background-color: #F5F5F5;
  padding: 0 60rpx;
}

.login-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
}

.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 120rpx;
}

.logo-placeholder {
  width: 180rpx;
  height: 180rpx;
  border-radius: 36rpx;
  background-color: #1890FF;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.logo-text {
  font-size: 44rpx;
  font-weight: bold;
  color: #FFFFFF;
}

.app-description {
  font-size: 30rpx;
  color: #666666;
}

.action-section {
  width: 100%;
}

.login-btn {
  width: 100%;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin: 0;
  background-color: #1890FF;
  color: #FFFFFF;
  font-size: 34rpx;
  font-weight: 500;
  border-radius: 48rpx;
  border: none;
}

.login-btn[disabled] {
  background-color: #91C9FF;
  color: #FFFFFF;
}
