/* Login Page — Upgraded UI/UX */

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(30rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes floatShadow {
  0%, 100% { box-shadow: 0 8rpx 32rpx rgba(24, 144, 255, 0.25); }
  50% { box-shadow: 0 16rpx 48rpx rgba(24, 144, 255, 0.4); }
}

@keyframes checkPop {
  0% { transform: scale(0.8); }
  50% { transform: scale(1.15); }
  100% { transform: scale(1); }
}

.login-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  background-color: var(--color-bg-page);
  padding: 0 60rpx;
  position: relative;
  overflow: hidden;
}

.login-page::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 50vh;
  background: var(--gradient-hero);
  opacity: 0.12;
  pointer-events: none;
}

.login-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  position: relative;
  z-index: 1;
  animation: fadeIn var(--duration-slow, 0.5s) var(--ease-out, ease-out) both;
}

.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 100rpx;
}

.logo-placeholder {
  width: 200rpx;
  height: 200rpx;
  border-radius: 40rpx;
  background: var(--gradient-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 36rpx;
  animation: floatShadow 3s ease-in-out infinite;
}

.logo-text {
  font-size: 48rpx;
  font-weight: bold;
  color: var(--color-text-white);
}

.app-description {
  font-size: 32rpx;
  color: var(--color-text-secondary);
  letter-spacing: 2rpx;
}

.action-section {
  width: 100%;
}

.login-btn {
  width: 100%;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin: 0;
  background: var(--gradient-primary);
  color: var(--color-text-white);
  font-size: 34rpx;
  font-weight: 600;
  border-radius: var(--radius-full, 999rpx);
  border: none;
  box-shadow: var(--shadow-primary);
  transition: transform var(--duration-fast, 0.2s) var(--ease-out, ease-out),
              box-shadow var(--duration-fast, 0.2s) var(--ease-out, ease-out);
}

.login-btn:active {
  transform: scale(0.97);
  box-shadow: 0 2rpx 8rpx rgba(24, 144, 255, 0.2);
}

.login-btn[disabled] {
  background: linear-gradient(135deg, #91C9FF 0%, #A3E4E0 100%);
  color: var(--color-text-white);
  box-shadow: none;
}

.login-btn::after {
  border: none;
}

/* Phone Login Form */
.phone-login-section {
  width: 100%;
}

.phone-form {
  background-color: var(--color-bg-card);
  border-radius: var(--radius-xl, 24rpx);
  padding: 40rpx 32rpx;
  margin-bottom: 40rpx;
  box-shadow: var(--shadow-card-elevated, 0 8rpx 32rpx rgba(0, 0, 0, 0.08));
}

.form-group {
  margin-bottom: 28rpx;
}

.form-group:last-child {
  margin-bottom: 0;
}

.form-input {
  width: 100%;
  height: 92rpx;
  border: 2rpx solid var(--color-border-input);
  border-radius: var(--radius-lg, 16rpx);
  padding: 0 28rpx;
  font-size: 30rpx;
  color: var(--color-text-primary);
  background-color: var(--color-bg-input, #F7F8FA);
  box-sizing: border-box;
  transition: border-color var(--duration-fast, 0.2s) var(--ease-out, ease-out),
              box-shadow var(--duration-fast, 0.2s) var(--ease-out, ease-out);
}

.form-input:focus {
  border-color: var(--color-primary);
  box-shadow: 0 0 0 4rpx rgba(24, 144, 255, 0.12);
}

.phone-row {
  display: flex;
  align-items: center;
}

.phone-input {
  flex: 1;
  margin-right: 16rpx;
}

.otp-btn {
  width: auto !important;
  min-width: 0 !important;
  margin: 0 !important;
  height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--color-primary-dark, #096DD9);
  color: var(--color-text-white);
  font-size: 24rpx;
  font-weight: 500;
  border-radius: var(--radius-full, 999rpx);
  border: none;
  flex-shrink: 0;
  padding: 0 28rpx !important;
  white-space: nowrap;
  transition: background-color var(--duration-fast, 0.2s);
}

.otp-btn:active {
  background-color: var(--color-primary);
}

.otp-btn[disabled] {
  background-color: #C4C4C4;
  color: var(--color-text-white);
}

.otp-btn::after {
  border: none;
}

.phone-submit-btn {
  margin-top: 8rpx;
}

/* Switch Login */
.switch-login {
  text-align: center;
  margin-top: 36rpx;
  padding: 16rpx;
}

.switch-login-text {
  font-size: 28rpx;
  color: var(--color-primary);
  text-decoration: underline;
  text-underline-offset: 6rpx;
}

/* Agreement */
.agreement-section {
  margin-top: 48rpx;
  padding: 0 16rpx;
}

.agreement-checkbox {
  display: flex;
  align-items: flex-start;
}

.checkbox-icon {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid var(--color-border-input);
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 2rpx;
  margin-right: 14rpx;
  transition: background-color var(--duration-fast, 0.2s),
              border-color var(--duration-fast, 0.2s),
              transform var(--duration-fast, 0.2s);
}

.checkbox-icon.checked {
  background-color: var(--color-primary);
  border-color: var(--color-primary);
  animation: checkPop 0.3s var(--ease-out, ease-out);
}

.check-mark {
  font-size: 24rpx;
  color: var(--color-text-white);
  line-height: 1;
}

.agreement-text {
  font-size: 25rpx;
  color: var(--color-text-hint);
  line-height: var(--line-height-relaxed, 1.7);
}

.agreement-link {
  color: var(--color-primary);
}
