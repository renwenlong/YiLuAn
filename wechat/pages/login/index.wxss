.login-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  background-color: #F5F5F5;
  padding: 0 60rpx;
}

.login-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
}

.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 120rpx;
}

.logo-placeholder {
  width: 180rpx;
  height: 180rpx;
  border-radius: 36rpx;
  background-color: #1890FF;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.logo-text {
  font-size: 44rpx;
  font-weight: bold;
  color: #FFFFFF;
}

.app-description {
  font-size: 30rpx;
  color: #666666;
}

.action-section {
  width: 100%;
}

.login-btn {
  width: 100%;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin: 0;
  background-color: #1890FF;
  color: #FFFFFF;
  font-size: 34rpx;
  font-weight: 500;
  border-radius: 48rpx;
  border: none;
}

.login-btn[disabled] {
  background-color: #91C9FF;
  color: #FFFFFF;
}

.login-btn::after {
  border: none;
}

/* 手机号登录表单 */
.phone-login-section {
  width: 100%;
}

.phone-form {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 40rpx;
}

.form-group {
  margin-bottom: 24rpx;
}

.form-group:last-child {
  margin-bottom: 0;
}

.form-input {
  width: 100%;
  height: 88rpx;
  border: 1rpx solid #D9D9D9;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #333333;
  box-sizing: border-box;
}

.phone-row {
  display: flex;
  align-items: center;
}

.phone-input {
  flex: 1;
  margin-right: 16rpx;
}

.otp-btn {
  width: auto !important;
  min-width: 0 !important;
  margin: 0 !important;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #1890FF;
  color: #FFFFFF;
  font-size: 24rpx;
  border-radius: 12rpx;
  border: none;
  flex-shrink: 0;
  padding: 0 20rpx !important;
  white-space: nowrap;
}

.otp-btn[disabled] {
  background-color: #B5B5B5;
  color: #FFFFFF;
}

.otp-btn::after {
  border: none;
}

.phone-submit-btn {
  margin-top: 0;
}

/* 切换登录方式 */
.switch-login {
  text-align: center;
  margin-top: 32rpx;
  padding: 16rpx;
}

.switch-login-text {
  font-size: 28rpx;
  color: #1890FF;
}

/* 协议勾选 */
.agreement-section {
  margin-top: 40rpx;
  padding: 0 16rpx;
}

.agreement-checkbox {
  display: flex;
  align-items: flex-start;
}

.checkbox-icon {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #D9D9D9;
  border-radius: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 4rpx;
  margin-right: 12rpx;
}

.checkbox-icon.checked {
  background-color: #1890FF;
  border-color: #1890FF;
}

.check-mark {
  font-size: 22rpx;
  color: #FFFFFF;
  line-height: 1;
}

.agreement-text {
  font-size: 24rpx;
  color: #999999;
  line-height: 1.6;
}

.agreement-link {
  color: #1890FF;
}
