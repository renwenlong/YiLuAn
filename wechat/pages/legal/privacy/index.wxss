.legal-page {
  padding: 32rpx;
  background-color: #FFFFFF;
  height: 100vh;
  box-sizing: border-box;
}

.legal-title {
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 16rpx;
  color: #333333;
}

.legal-meta {
  font-size: 24rpx;
  color: #999999;
  text-align: center;
  margin-bottom: 40rpx;
}

.legal-section {
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 16rpx;
  line-height: 1.8;
}

.subsection-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  margin: 16rpx 0 8rpx;
  line-height: 1.8;
}

.section-body {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.8;
}

.list-item {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.8;
  padding-left: 16rpx;
}

.legal-footer {
  font-size: 24rpx;
  color: #999999;
  text-align: center;
  margin-top: 48rpx;
  padding-top: 32rpx;
  padding-bottom: 120rpx;
  border-top: 1rpx solid #EEEEEE;
}

/* 返回顶部按钮 */
.back-to-top {
  position: fixed;
  right: 32rpx;
  bottom: calc(80rpx + env(safe-area-inset-bottom));
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: #FFFFFF;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.12);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transform: scale(0.6);
  transition: opacity 0.3s ease, transform 0.3s ease;
  pointer-events: none;
  z-index: 100;
}

.back-to-top-show {
  opacity: 1;
  transform: scale(1);
  pointer-events: auto;
}

.back-to-top-arrow {
  font-size: 28rpx;
  color: #1890FF;
  line-height: 1;
}

.back-to-top-text {
  font-size: 18rpx;
  color: #1890FF;
  line-height: 1;
  margin-top: 2rpx;
}
