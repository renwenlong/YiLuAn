.role-select-page {
  min-height: 100vh;
  background-color: var(--color-bg-page);
  padding: 80rpx 40rpx;
  box-sizing: border-box;
}

.page-header {
  text-align: center;
  margin-bottom: 80rpx;
}

.title {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: var(--color-text-primary);
  margin-bottom: 16rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: var(--color-text-hint);
}

.role-cards {
  display: flex;
  flex-direction: column;
  gap: 40rpx;
}

.role-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  background-color: var(--color-bg-card);
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.role-card:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.role-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.patient-icon {
  background-color: rgba(24, 144, 255, 0.1);
}

.companion-icon {
  background-color: rgba(82, 196, 26, 0.1);
}

.icon-text {
  font-size: 44rpx;
  font-weight: bold;
}

.patient-icon .icon-text {
  color: var(--color-primary);
}

.companion-icon .icon-text {
  color: var(--color-success);
}

.role-name {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 12rpx;
}

.role-desc {
  font-size: 28rpx;
  color: var(--color-text-hint);
}

.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid var(--color-bg-card);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}
