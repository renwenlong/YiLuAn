/* Role Select Page — Upgraded UI/UX */

@keyframes slideUp {
  from { opacity: 0; transform: translateY(60rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.role-select-page {
  min-height: 100vh;
  background-color: var(--color-bg-page);
  padding: 80rpx 40rpx;
  box-sizing: border-box;
}

.page-header {
  text-align: center;
  margin-bottom: 80rpx;
}

.title {
  display: block;
  font-size: var(--font-size-hero, 48rpx);
  font-weight: bold;
  color: var(--color-text-primary);
  margin-bottom: 16rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: var(--color-text-hint);
}

.role-cards {
  display: flex;
  flex-direction: column;
  gap: 40rpx;
}

.role-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  background-color: var(--color-bg-card);
  border-radius: var(--radius-xl, 24rpx);
  padding: 60rpx 40rpx;
  box-shadow: var(--shadow-card, 0 4rpx 16rpx rgba(0, 0, 0, 0.06));
  border-left: 6rpx solid transparent;
  transition: transform var(--duration-normal, 0.3s) var(--ease-out, ease-out),
              box-shadow var(--duration-normal, 0.3s) var(--ease-out, ease-out);
  animation: slideUp var(--duration-slow, 0.5s) var(--ease-out, ease-out) both;
}

.role-card:nth-child(1) {
  border-left-color: var(--color-primary);
  animation-delay: 0.05s;
}

.role-card:nth-child(2) {
  border-left-color: var(--color-success, #52C41A);
  animation-delay: 0.15s;
}

.role-card:active {
  transform: scale(0.96);
  box-shadow: var(--shadow-card-elevated, 0 12rpx 40rpx rgba(0, 0, 0, 0.12));
}

.role-icon {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 28rpx;
}

.patient-icon {
  background: linear-gradient(135deg, rgba(24, 144, 255, 0.1), rgba(54, 207, 201, 0.15));
}

.companion-icon {
  background: linear-gradient(135deg, rgba(82, 196, 26, 0.1), rgba(115, 209, 61, 0.15));
}

.icon-text {
  font-size: 48rpx;
  font-weight: bold;
}

.patient-icon .icon-text {
  color: var(--color-primary);
}

.companion-icon .icon-text {
  color: var(--color-success, #52C41A);
}

.role-name {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 12rpx;
}

.role-desc {
  font-size: 28rpx;
  color: var(--color-text-hint);
}

/* Loading Mask */
.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: var(--z-modal, 999);
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
