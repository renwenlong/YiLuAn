/* Chat Room — Upgraded UI/UX */

.chat-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: var(--color-bg-page, #F7F8FA);
}

/* Message List */
.message-list {
  flex: 1;
  overflow-y: auto;
}

.message-padding-top {
  height: 24rpx;
}

.message-padding-bottom {
  height: 24rpx;
}

/* Input Bar */
.input-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 24rpx;
  background-color: #FFFFFF;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.04);
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}

.input-wrapper {
  flex: 1;
  background-color: var(--color-bg-input, #F7F8FA);
  border-radius: var(--radius-full, 999rpx);
  padding: 0 28rpx;
  transition: box-shadow var(--duration-fast, 0.2s);
}

.input-wrapper:focus-within {
  box-shadow: 0 0 0 3rpx rgba(24, 144, 255, 0.15);
}

.chat-input {
  height: 76rpx;
  font-size: 28rpx;
  color: var(--color-text-primary, #333);
}

.send-btn {
  width: 128rpx;
  height: 76rpx;
  line-height: 76rpx;
  font-size: 28rpx;
  font-weight: 500;
  background-color: var(--color-border-light, #E0E0E0);
  color: #FFFFFF;
  border-radius: var(--radius-full, 999rpx);
  padding: 0;
  flex-shrink: 0;
  transition: background var(--duration-fast, 0.2s),
              box-shadow var(--duration-fast, 0.2s);
}

.send-btn.active {
  background: var(--gradient-primary);
  box-shadow: var(--shadow-primary);
}

.send-btn[disabled] {
  background-color: var(--color-border-light, #E0E0E0);
  color: #FFFFFF;
  box-shadow: none;
}
