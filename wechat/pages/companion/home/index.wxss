.companion-home {
  min-height: 100vh;
  background-color: #F5F5F5;
  padding: 24rpx;
  padding-bottom: 140rpx;
  box-sizing: border-box;
}

.stats-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 40rpx 24rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-value {
  font-size: 44rpx;
  font-weight: bold;
  color: #1890FF;
  margin-bottom: 8rpx;
}

.open-orders-value {
  color: #FF4D4F;
}

.stat-label {
  font-size: 24rpx;
  color: #999999;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background-color: #E8E8E8;
}

.section {
  margin-bottom: 32rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333333;
}

.section-title-wrap {
  display: flex;
  align-items: center;
}

.pending-badge {
  background: #FF4D4F;
  color: #fff;
  font-size: 22rpx;
  min-width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  border-radius: 18rpx;
  padding: 0 10rpx;
  margin-left: 12rpx;
}

.section-link {
  font-size: 26rpx;
  color: #1890FF;
}

.view-more {
  text-align: center;
  padding: 24rpx 0 8rpx;
  color: #1890FF;
  font-size: 26rpx;
}

.order-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.empty-hint {
  text-align: center;
  padding: 60rpx 0;
  color: #999999;
  font-size: 28rpx;
}

.bottom-spacer {
  height: 120rpx;
}
