.companion-home {
  min-height: 100vh;
  background-color: var(--color-bg-page);
  padding: var(--spacing-lg);
  padding-bottom: 180rpx;
  box-sizing: border-box;
}

/* Stats Row — Hero Gradient */
.stats-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
  background: var(--gradient-hero);
  border-radius: var(--radius-lg);
  padding: 48rpx var(--spacing-lg);
  margin-bottom: var(--spacing-xl);
  box-shadow: var(--shadow-primary);
  position: relative;
  overflow: hidden;
}

.stats-row::before {
  content: '';
  position: absolute;
  top: -40%;
  right: -20%;
  width: 300rpx;
  height: 300rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  position: relative;
  z-index: 1;
}

.stat-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: var(--spacing-xs);
  line-height: var(--line-height-tight, 1.2);
}

.stat-label {
  font-size: var(--font-size-xs);
  color: rgba(255, 255, 255, 0.8);
  line-height: var(--line-height-normal, 1.5);
}

.stat-divider {
  width: 1rpx;
  height: 64rpx;
  background-color: rgba(255, 255, 255, 0.2);
  flex-shrink: 0;
}

/* Open orders pill — warning highlight */
.open-orders-value {
  color: var(--color-warning, #FAAD14) !important;
  background: #FFFFFF;
  border-radius: var(--radius-full, 999rpx);
  padding: 4rpx 20rpx;
  font-size: 44rpx;
}

/* Section */
.section {
  margin-bottom: var(--spacing-xl);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--spacing-md);
}

.section-title {
  font-size: var(--font-size-lg);
  font-weight: 600;
  color: var(--color-text-primary);
  line-height: var(--line-height-tight, 1.2);
}

.section-title-wrap {
  display: flex;
  align-items: center;
}

.pending-badge {
  background: var(--color-error, #FF4D4F);
  color: #FFFFFF;
  font-size: var(--font-size-xs);
  min-width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  border-radius: var(--radius-full, 999rpx);
  padding: 0 10rpx;
  margin-left: var(--spacing-sm);
  font-weight: 600;
}

.section-link {
  font-size: var(--font-size-sm);
  color: var(--color-primary, #1890FF);
  transition: opacity var(--duration-fast, 200ms) var(--ease-out, ease-out);
}

.section-link:active {
  opacity: 0.7;
}

.view-more {
  text-align: center;
  padding: var(--spacing-lg) 0 var(--spacing-xs);
  color: var(--color-primary, #1890FF);
  font-size: var(--font-size-sm);
  transition: opacity var(--duration-fast, 200ms) var(--ease-out, ease-out);
}

.view-more:active {
  opacity: 0.7;
}

/* Order list */
.order-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-md);
}

/* Empty hint */
.empty-hint {
  text-align: center;
  padding: 80rpx var(--spacing-xl);
  color: var(--color-text-quaternary, #C0C0C0);
  font-size: var(--font-size-base);
  line-height: var(--line-height-relaxed, 1.8);
}

/* Bottom spacer */
.bottom-spacer {
  height: 160rpx;
}
