<view class="companion-home">
  <!-- 数据统计 -->
  <view class="stats-row">
    <view class="stat-item" bindtap="onOpenOrdersTap">
      <text class="stat-value open-orders-value">{{stats.openOrders}}</text>
      <text class="stat-label">未结订单</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-value">{{stats.totalEarnings}}</text>
      <text class="stat-label">累计收入(元)</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-value">{{stats.rating || '-'}}</text>
      <text class="stat-label">评分</text>
    </view>
  </view>

  <!-- 待接订单 -->
  <view class="section">
    <view class="section-header">
      <view class="section-title-wrap">
        <text class="section-title">待接订单</text>
        <text class="pending-badge" wx:if="{{pendingTotal > 0}}">{{pendingTotal}}</text>
      </view>
      <text class="section-link" bindtap="onViewAllPending">查看全部待接单</text>
    </view>
    <view class="order-list" wx:if="{{pendingOrders.length > 0}}">
      <order-card
        wx:for="{{pendingOrders}}"
        wx:key="id"
        order="{{item}}"
        data-id="{{item.id}}"
        bindtap="onOrderTap"
      />
    </view>
    <view class="view-more" wx:if="{{pendingTotal > 3}}" bindtap="onViewAllPending">
      <text>查看全部 {{pendingTotal}} 条待接订单</text>
    </view>
    <view class="empty-hint" wx:if="{{pendingOrders.length === 0}}">
      <text>暂无待接订单</text>
    </view>
  </view>

  <!-- 底部占位，防止内容被导航栏遮挡 -->
  <view class="bottom-spacer"></view>
</view>

<companion-tab-bar active="home" />
