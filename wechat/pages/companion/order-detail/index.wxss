.page-container {
  padding-bottom: 160rpx;
}

/* Status Header */
.status-header {
  padding: 48rpx 32rpx;
  color: #fff;
  text-align: center;
}

.status-header.status-created { background-color: #FF9800; }
.status-header.status-accepted { background-color: #2196F3; }
.status-header.status-in_progress { background-color: #4CAF50; }
.status-header.status-completed { background-color: #9E9E9E; }
.status-header.status-reviewed { background-color: #4CAF50; }
.status-header.status-cancelled { background-color: #F44336; }

.status-text {
  font-size: 36rpx;
  font-weight: bold;
}

/* Detail Section */
.detail-section {
  margin: 24rpx;
  padding: 32rpx;
  background-color: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 16rpx 0;
}

.info-label {
  font-size: 28rpx;
  color: #999;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  text-align: right;
  word-break: break-all;
}

.info-value.price {
  color: #e53935;
  font-weight: bold;
}

/* Patient Card */
.patient-card {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.patient-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.patient-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.patient-phone {
  font-size: 26rpx;
  color: #4CAF50;
}

/* Timeline */
.timeline {
  padding-left: 16rpx;
}

.timeline-item {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  padding-bottom: 32rpx;
  position: relative;
}

.timeline-item:not(:last-child)::after {
  content: '';
  position: absolute;
  left: 12rpx;
  top: 32rpx;
  bottom: 0;
  width: 2rpx;
  background-color: #e0e0e0;
}

.timeline-item.active:not(:last-child)::after {
  background-color: #4CAF50;
}

.timeline-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background-color: #e0e0e0;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.timeline-item.active .timeline-dot {
  background-color: #4CAF50;
}

.timeline-content {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.timeline-title {
  font-size: 28rpx;
  color: #333;
}

.timeline-time {
  font-size: 24rpx;
  color: #999;
}

/* Action Bar */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 16rpx;
  padding: 24rpx 32rpx;
  background-color: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.08);
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.btn-primary {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  background-color: #4CAF50;
  color: #fff;
  border-radius: 16rpx;
  font-weight: bold;
  padding: 0;
}

.btn-secondary {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  background-color: #f5f5f5;
  color: #666;
  border-radius: 16rpx;
  padding: 0;
}

/* Review Card */
.review-card {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.review-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.review-author {
  font-size: 24rpx;
  color: #999;
  text-align: right;
}

/* Review Pending Hint */
.review-pending-hint {
  margin: 24rpx;
  padding: 32rpx;
  background-color: #fffbe6;
  border-radius: 16rpx;
  text-align: center;
  border: 1rpx solid #ffe58f;
}

.pending-text {
  font-size: 28rpx;
  color: #faad14;
}
