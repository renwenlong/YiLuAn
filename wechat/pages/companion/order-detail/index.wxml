<loading-overlay wx:if="{{loading}}" />

<view class="page-container" wx:if="{{order}}">
  <!-- Status Header -->
  <view class="status-header status-{{order.status}}">
    <text class="status-text">{{statusList[order.status] || order.status}}</text>
  </view>

  <!-- Order Info -->
  <view class="detail-section">
    <view class="section-title">订单信息</view>
    <view class="info-row">
      <text class="info-label">订单编号</text>
      <text class="info-value">{{order.id}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">服务类型</text>
      <text class="info-value">{{order.serviceType}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">医院</text>
      <text class="info-value">{{order.hospitalName}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">预约日期</text>
      <text class="info-value">{{order.formattedDate}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">预约时间</text>
      <text class="info-value">{{order.time}}</text>
    </view>
    <view class="info-row" wx:if="{{order.formattedPrice}}">
      <text class="info-label">费用</text>
      <text class="info-value price">{{order.formattedPrice}}</text>
    </view>
    <view class="info-row" wx:if="{{order.notes}}">
      <text class="info-label">备注</text>
      <text class="info-value">{{order.notes}}</text>
    </view>
  </view>

  <!-- Patient Info -->
  <view class="detail-section" wx:if="{{order.patient}}">
    <view class="section-title">患者信息</view>
    <view class="patient-card">
      <view class="patient-info">
        <text class="patient-name">{{order.patient.name}}</text>
        <text class="patient-phone" bindtap="onCallPatient">{{order.patient.phone}}</text>
      </view>
    </view>
    <view class="info-row" wx:if="{{order.patient.age}}">
      <text class="info-label">年龄</text>
      <text class="info-value">{{order.patient.age}}岁</text>
    </view>
    <view class="info-row" wx:if="{{order.patient.gender}}">
      <text class="info-label">性别</text>
      <text class="info-value">{{order.patient.gender}}</text>
    </view>
  </view>

  <!-- Status Timeline -->
  <view class="detail-section" wx:if="{{order.timeline && order.timeline.length > 0}}">
    <view class="section-title">订单进度</view>
    <view class="timeline">
      <view class="timeline-item {{index <= order.timelineIndex ? 'active' : ''}}" wx:for="{{order.timeline}}" wx:key="time">
        <view class="timeline-dot"></view>
        <view class="timeline-content">
          <text class="timeline-title">{{item.title}}</text>
          <text class="timeline-time">{{item.time}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Action Buttons -->
  <view class="action-bar">
    <!-- Created: accept -->
    <block wx:if="{{order.status === 'created'}}">
      <button class="btn-primary" bindtap="onAccept">接受订单</button>
    </block>

    <!-- Accepted: start + chat -->
    <block wx:if="{{order.status === 'accepted'}}">
      <button class="btn-primary" bindtap="onStart">开始服务</button>
      <button class="btn-secondary" bindtap="onChat">联系患者</button>
    </block>

    <!-- In Progress: complete + chat -->
    <block wx:if="{{order.status === 'in_progress'}}">
      <button class="btn-primary" bindtap="onComplete">完成服务</button>
      <button class="btn-secondary" bindtap="onChat">联系患者</button>
    </block>

    <!-- Completed: chat only -->
    <block wx:if="{{order.status === 'completed'}}">
      <button class="btn-secondary" bindtap="onChat">联系患者</button>
    </block>
  </view>
</view>
