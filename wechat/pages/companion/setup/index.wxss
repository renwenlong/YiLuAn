.setup-page {
  min-height: 100vh;
  background-color: #F5F5F5;
  padding: 40rpx;
  padding-bottom: 200rpx;
  box-sizing: border-box;
}

.page-header {
  text-align: center;
  margin-bottom: 48rpx;
}

.title {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 12rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: #999999;
}

.form-section {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 32rpx;
}

.form-group {
  margin-bottom: 36rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333333;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.required {
  color: #FF4D4F;
}

.recommend {
  color: #1890FF;
  font-size: 24rpx;
  font-weight: 400;
}

.form-hint-text {
  display: block;
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 16rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  border: 1rpx solid #D9D9D9;
  border-radius: 8rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  border: 1rpx solid #D9D9D9;
  border-radius: 8rpx;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
}

.form-textarea-sm {
  min-height: 0;
  height: 80rpx;
}

.form-hint {
  font-size: 26rpx;
  color: #999999;
}

/* Service type multi-select */

/* Phone input */
.phone-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.phone-input {
  flex: 1;
  margin-right: 16rpx;
}

.otp-btn {
  width: auto !important;
  min-width: 0 !important;
  margin: 0 !important;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background-color: #1890FF;
  color: #FFFFFF;
  font-size: 24rpx;
  border-radius: 8rpx;
  border: none;
  flex-shrink: 0;
  padding: 0 24rpx !important;
  white-space: nowrap;
}

.otp-btn[disabled] {
  background-color: #B5B5B5;
  color: #FFFFFF;
}

.otp-btn::after {
  border: none;
}

.code-row {
  display: flex;
  align-items: center;
}

.code-input {
  flex: 1;
  margin-right: 16rpx;
}

.verify-btn {
  width: 160rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background-color: #52C41A;
  color: #FFFFFF;
  font-size: 28rpx;
  border-radius: 8rpx;
  border: none;
  flex-shrink: 0;
  padding: 0;
}

.verify-btn[disabled] {
  background-color: #B5B5B5;
  color: #FFFFFF;
}

.verify-btn::after {
  border: none;
}

.phone-bound-row {
  display: flex;
  align-items: center;
  height: 80rpx;
  padding: 0 24rpx;
  border: 1rpx solid #D9D9D9;
  border-radius: 8rpx;
  background: #FAFAFA;
}

.phone-bound-text {
  font-size: 28rpx;
  color: #333333;
  flex: 1;
}

.phone-bound-tag {
  font-size: 24rpx;
  color: #52C41A;
  font-weight: 600;
}

/* Service type multi-select */
.tag-select-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-select-item {
  display: flex;
  align-items: center;
  padding: 18rpx 28rpx;
  border: 2rpx solid #D9D9D9;
  border-radius: 12rpx;
  background: #FAFAFA;
}

.tag-select-item.selected {
  border-color: #1890FF;
  background: #E6F7FF;
}

.tag-select-name {
  font-size: 28rpx;
  color: #333333;
}

.tag-select-item.selected .tag-select-name {
  color: #1890FF;
  font-weight: 600;
}

.tag-select-check {
  font-size: 28rpx;
  color: #1890FF;
  font-weight: 600;
  margin-left: 8rpx;
}

/* District select */
.district-select-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.district-select-item {
  display: flex;
  align-items: center;
  padding: 14rpx 24rpx;
  border: 1rpx solid #D9D9D9;
  border-radius: 8rpx;
  background: #FAFAFA;
}

.district-select-item.selected {
  border-color: #1890FF;
  background: #E6F7FF;
}

.district-select-name {
  font-size: 26rpx;
  color: #333333;
}

.district-select-check {
  font-size: 28rpx;
  color: #1890FF;
  font-weight: 600;
  margin-left: 8rpx;
}

/* Search */
.search-bar {
  margin-bottom: 16rpx;
}

.search-input {
  width: 100%;
  height: 72rpx;
  border: 1rpx solid #D9D9D9;
  border-radius: 8rpx;
  padding: 0 24rpx;
  font-size: 26rpx;
  color: #333333;
  box-sizing: border-box;
  background: #FAFAFA;
}

/* Filters - picker dropdown style */
.filter-section {
  margin-bottom: 16rpx;
}

.filter-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.filter-picker-wrap {
  flex: 1;
}

.filter-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 64rpx;
  padding: 0 20rpx;
  border: 1rpx solid #D9D9D9;
  border-radius: 8rpx;
  background: #FAFAFA;
}

.filter-picker-text {
  font-size: 24rpx;
  color: #333333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.filter-picker-arrow {
  font-size: 20rpx;
  color: #999999;
  margin-left: 8rpx;
  flex-shrink: 0;
}

/* Hospital list */
.hospital-select-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  max-height: 600rpx;
  overflow-y: auto;
}

.hospital-select-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  border: 1rpx solid #D9D9D9;
  border-radius: 8rpx;
  background: #FAFAFA;
}

.hospital-select-item.selected {
  border-color: #1890FF;
  background: #E6F7FF;
}

.hospital-info {
  flex: 1;
  min-width: 0;
}

.hospital-select-name {
  display: block;
  font-size: 28rpx;
  color: #333333;
}

.hospital-meta {
  display: flex;
  gap: 16rpx;
  margin-top: 6rpx;
}

.hospital-meta-text {
  font-size: 22rpx;
  color: #999999;
}

.hospital-select-check {
  font-size: 32rpx;
  color: #1890FF;
  font-weight: 600;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.selected-count {
  display: block;
  font-size: 24rpx;
  color: #1890FF;
  margin-top: 12rpx;
}

/* Submit */
.btn-section {
  margin-top: 48rpx;
}

.btn-submit {
  width: 100%;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #1890FF, #36CFC9);
  color: #FFFFFF;
  font-size: 32rpx;
  border-radius: 44rpx;
  border: none;
  font-weight: 600;
}

.btn-submit:active {
  opacity: 0.9;
}

.btn-submit[disabled] {
  background: #B5B5B5;
  color: #FFFFFF;
}

.btn-submit::after {
  border: none;
}

.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid #FFFFFF;
  border-top-color: #1890FF;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}
