.page-container {
  padding: var(--spacing-lg);
  padding-bottom: 60rpx;
  min-height: 100vh;
  background-color: var(--color-bg-page);
  box-sizing: border-box;
}

/* Order list */
.order-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-lg);
}

/* Card wrapper with fade-in */
.order-card-wrapper {
  background-color: var(--color-bg-card, #FFFFFF);
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-card, 0 2rpx 16rpx rgba(0, 0, 0, 0.06));
  transition: box-shadow var(--duration-normal, 300ms) var(--ease-out, ease-out),
              transform var(--duration-normal, 300ms) var(--ease-out, ease-out);
  animation: card-fade-in var(--duration-slow, 400ms) var(--ease-out, ease-out) both;
}

.order-card-wrapper:active {
  box-shadow: var(--shadow-sm, 0 1rpx 8rpx rgba(0, 0, 0, 0.04));
}

@keyframes card-fade-in {
  from {
    opacity: 0;
    transform: translateY(16rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.order-card-wrapper:nth-child(1) { animation-delay: 0ms; }
.order-card-wrapper:nth-child(2) { animation-delay: 60ms; }
.order-card-wrapper:nth-child(3) { animation-delay: 120ms; }
.order-card-wrapper:nth-child(4) { animation-delay: 180ms; }
.order-card-wrapper:nth-child(5) { animation-delay: 240ms; }

/* Accept action area */
.accept-action {
  padding: 0 var(--spacing-lg) var(--spacing-lg);
  display: flex;
  justify-content: flex-end;
}

.btn-accept {
  width: 220rpx;
  height: 76rpx;
  line-height: 76rpx;
  font-size: var(--font-size-base);
  background: var(--gradient-success);
  color: #FFFFFF;
  border-radius: var(--radius-full, 999rpx);
  font-weight: 600;
  padding: 0;
  border: none;
  box-shadow: var(--shadow-success);
  transition: transform var(--duration-fast, 200ms) var(--ease-out, ease-out),
              box-shadow var(--duration-fast, 200ms) var(--ease-out, ease-out);
}

.btn-accept:active {
  transform: scale(0.96);
  box-shadow: 0 2rpx 8rpx rgba(82, 196, 26, 0.2);
}

/* Load more / no more */
.load-more,
.no-more {
  text-align: center;
  padding: var(--spacing-xl) 0;
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary, #999999);
  line-height: var(--line-height-normal, 1.5);
}

.load-more {
  color: var(--color-primary, #1890FF);
}
