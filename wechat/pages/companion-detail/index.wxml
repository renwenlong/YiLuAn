<loading-overlay wx:if="{{loading}}" />

<view class="page-container" wx:if="{{companion}}">
  <!-- Profile Header -->
  <view class="profile-header">
    <view class="profile-header-decor"></view>
    <image
      class="profile-avatar"
      src="{{companion.avatar}}"
      mode="aspectFill"
      bindtap="onPreviewAvatar"
    />
    <view class="profile-name-row">
      <text class="profile-name">{{companion.name}}</text>
      <text wx:if="{{companion.is_verified}}" class="verified-badge">已认证</text>
      <text wx:else class="unverified-badge">未认证</text>
    </view>
    <view class="profile-rating" wx:if="{{companion.rating > 0}}">
      <rating-stars value="{{companion.rating}}" readonly="{{true}}" />
      <text class="rating-text">{{companion.rating}}分</text>
    </view>
    <view class="profile-rating" wx:else>
      <text class="rating-text no-rating-text">暂无评分</text>
    </view>
  </view>

  <!-- Bio -->
  <view class="detail-section">
    <view class="section-title">个人简介</view>
    <text class="bio-text">{{companion.bio || '暂无简介'}}</text>
  </view>

  <!-- Service Info -->
  <view class="detail-section">
    <view class="section-title">服务信息</view>
    <view class="info-row">
      <text class="info-label">服务区域</text>
      <text class="info-value">{{companion.serviceArea || '暂无'}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">已完成订单</text>
      <text class="info-value">{{companion.completedOrders || 0}}单</text>
    </view>
    <view class="info-row">
      <text class="info-label">从业时间</text>
      <text class="info-value">{{companion.experience || '暂无'}}</text>
    </view>

    <view class="service-areas" wx:if="{{companion.serviceAreas && companion.serviceAreas.length > 0}}">
      <text class="info-label">擅长领域</text>
      <view class="tag-list">
        <text class="tag" wx:for="{{companion.serviceAreas}}" wx:key="*this">{{item}}</text>
      </view>
    </view>
  </view>

  <!-- Reviews -->
  <view class="detail-section">
    <view class="section-title">用户评价 ({{reviews.length}})</view>
    <view class="review-list" wx:if="{{reviews.length > 0}}">
      <view class="review-item" wx:for="{{reviews}}" wx:key="id">
        <view class="review-header">
          <text class="review-user">{{item.userName}}</text>
          <rating-stars value="{{item.rating}}" readonly="{{true}}" size="small" />
        </view>
        <text class="review-content">{{item.content}}</text>
        <text class="review-date">{{item.date}}</text>
      </view>
    </view>
    <view class="empty-reviews">
      <text class="empty-reviews-icon">💬</text>
      <text>期待第一条评价</text>
    </view>
  </view>

  <!-- Bottom Spacer for fixed button -->
  <view class="bottom-spacer"></view>

  <!-- Book Button -->
  <view class="book-bar">
    <button class="btn-book" bindtap="onBook">预约陪诊</button>
  </view>
</view>
