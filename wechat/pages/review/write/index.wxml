<loading-overlay wx:if="{{loading}}" />

<view class="page-container">
  <!-- F-04: 4-dimension star rating -->
  <view class="section">
    <view class="section-title">服务评分</view>

    <view class="dimension-row">
      <text class="dimension-label">守时</text>
      <rating-stars
        value="{{punctuality_rating}}"
        readonly="{{false}}"
        size="medium"
        bind:change="onPunctualityChange"
      />
      <text class="dimension-score">{{punctuality_rating}}分</text>
    </view>

    <view class="dimension-row">
      <text class="dimension-label">专业</text>
      <rating-stars
        value="{{professionalism_rating}}"
        readonly="{{false}}"
        size="medium"
        bind:change="onProfessionalismChange"
      />
      <text class="dimension-score">{{professionalism_rating}}分</text>
    </view>

    <view class="dimension-row">
      <text class="dimension-label">沟通</text>
      <rating-stars
        value="{{communication_rating}}"
        readonly="{{false}}"
        size="medium"
        bind:change="onCommunicationChange"
      />
      <text class="dimension-score">{{communication_rating}}分</text>
    </view>

    <view class="dimension-row">
      <text class="dimension-label">态度</text>
      <rating-stars
        value="{{attitude_rating}}"
        readonly="{{false}}"
        size="medium"
        bind:change="onAttitudeChange"
      />
      <text class="dimension-score">{{attitude_rating}}分</text>
    </view>

    <view class="overall-rating">
      <text class="overall-label">总评分</text>
      <text class="overall-value">{{overallRating}}分</text>
    </view>
  </view>

  <!-- Content Section -->
  <view class="section">
    <view class="section-title">评价内容</view>
    <textarea
      class="review-textarea"
      placeholder="请分享您的陪诊体验，帮助其他患者做出选择..."
      value="{{content}}"
      bindinput="onInput"
      maxlength="500"
      auto-height="{{false}}"
    />
    <view class="char-count">
      <text>{{content.length}}/500</text>
    </view>
  </view>

  <!-- Submit Button -->
  <view class="submit-wrapper">
    <button
      class="btn-submit"
      bindtap="onSubmit"
      loading="{{loading}}"
      disabled="{{loading}}"
    >提交评价</button>
  </view>
</view>
