.page-container {
  padding: 32rpx;
  min-height: 100vh;
  background-color: #f5f5f5;
  box-sizing: border-box;
}

/* Section */
.section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
}

/* F-04: dimension rating row */
.dimension-row {
  display: flex;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.dimension-row:last-child {
  border-bottom: none;
}

.dimension-label {
  width: 120rpx;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.dimension-score {
  margin-left: auto;
  font-size: 28rpx;
  color: #FF9800;
  font-weight: bold;
  min-width: 80rpx;
  text-align: right;
}

.overall-rating {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 2rpx dashed #eee;
}

.overall-label {
  font-size: 30rpx;
  color: #333;
  font-weight: bold;
}

.overall-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #FF5722;
}

/* Rating */
.rating-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  padding: 24rpx 0;
}

.rating-text {
  font-size: 40rpx;
  font-weight: bold;
  color: #FF9800;
}

.rating-labels {
  text-align: center;
  padding-top: 8rpx;
}

.rating-label {
  font-size: 28rpx;
  color: #666;
}

/* Textarea */
.review-textarea {
  width: 100%;
  height: 300rpx;
  padding: 24rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  box-sizing: border-box;
  background-color: #fafafa;
}

.review-textarea:focus {
  border-color: #4CAF50;
}

.char-count {
  text-align: right;
  padding-top: 12rpx;
  font-size: 24rpx;
  color: #999;
}

/* Submit */
.submit-wrapper {
  padding: 32rpx 0;
}

.btn-submit {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 34rpx;
  background-color: #4CAF50;
  color: #fff;
  border-radius: 16rpx;
  font-weight: bold;
  padding: 0;
}

.btn-submit:active {
  background-color: #388E3C;
}

.btn-submit[disabled] {
  background-color: #a5d6a7;
  color: #fff;
}
