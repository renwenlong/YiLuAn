.rating-stars {
  display: flex;
  align-items: center;
}

.star {
  font-size: 40rpx;
  margin-right: 8rpx;
  transform: translateZ(0);
  will-change: transform;
  transition: transform 0.2s ease, color 0.15s ease;
}

.star-filled {
  color: #faad14;
}

.star-empty {
  color: #d9d9d9;
}

.star-interactive {
  cursor: pointer;
}

.star-interactive:active {
  transform: translateZ(0) scale(1.2);
}

.star-pop {
  animation: star-pop-in 0.3s ease forwards;
}

@keyframes star-pop-in {
  0% {
    transform: translateZ(0) scale(1);
  }
  50% {
    transform: translateZ(0) scale(1.35) rotate(15deg);
  }
  100% {
    transform: translateZ(0) scale(1);
  }
}
