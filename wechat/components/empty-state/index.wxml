<view class="empty-state polish-empty-state" aria-role="status" aria-label="{{text}}">
  <view class="empty-icon" aria-hidden="true">
    <text class="icon-placeholder">{{icon}}</text>
  </view>
  <text class="empty-text">{{text}}</text>
  <text class="empty-hint" wx:if="{{hint}}">{{hint}}</text>
</view>
