.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.icon-placeholder {
  font-size: 48rpx;
  color: #d9d9d9;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* P-07: 补充提示文案、与 empty-text 呈上下层级 */
.empty-hint {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #bbb;
  line-height: 1.5;
  text-align: center;
}

/* P-12: 深色模式下提高空状态文字对比度 */
@media (prefers-color-scheme: dark) {
  .empty-text { color: #d1d5db; }
  .empty-hint { color: #9ca3af; }
  .empty-icon { background: #2a2a2a; }
  .icon-placeholder { color: #6b7280; }
}
