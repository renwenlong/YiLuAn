.service-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.service-card.active {
  border-color: #1890FF;
  background: #E6F7FF;
  box-shadow: 0 4rpx 16rpx rgba(24, 144, 255, 0.15);
}

.service-info {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.service-label {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 4rpx;
}

.service-card.active .service-label {
  color: #1890FF;
}

.service-desc {
  font-size: 24rpx;
  color: #999;
}

.service-card.active .service-desc {
  color: #69C0FF;
}

.service-price {
  font-size: 36rpx;
  font-weight: 700;
  color: #FF6B35;
  flex-shrink: 0;
}
