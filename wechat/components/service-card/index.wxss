.service-card {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  margin-bottom: 20rpx;
}

.service-info {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.service-label {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.service-price {
  font-size: 36rpx;
  font-weight: 700;
  color: #ff6b35;
}
