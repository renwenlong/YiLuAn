<view class="order-card" bindtap="onTap">
  <view class="order-header">
    <text class="order-service">{{serviceLabel}}</text>
    <view class="order-status" style="background: {{statusInfo.color}};">
      <text class="status-text">{{statusInfo.label}}</text>
    </view>
  </view>
  <view class="order-body">
    <view class="order-row">
      <text class="order-label">医院</text>
      <text class="order-value">{{order.hospital_name}}</text>
    </view>
    <view class="order-row">
      <text class="order-label">时间</text>
      <text class="order-value">{{order.appointment_date}} {{order.appointment_time}}</text>
    </view>
    <view class="order-row" wx:if="{{order.patient_name}}">
      <text class="order-label">患者</text>
      <text class="order-value">{{order.patient_name}}</text>
    </view>
    <view class="order-desc" wx:if="{{order.description}}">
      <text class="order-desc-text">{{order.description}}</text>
    </view>
  </view>
  <view class="order-footer">
    <text class="order-price">¥{{order.price}}</text>
  </view>
</view>
