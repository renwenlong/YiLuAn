.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background-color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: space-around;
  border-top: 1rpx solid #E8E8E8;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 999;
}

.tab-item {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 1;
  height: 100%;
}

.tab-label {
  font-size: 28rpx;
  color: #999999;
}

.tab-item.active .tab-label {
  color: #1890FF;
  font-weight: 600;
}

.tab-bar-spacer {
  height: 100rpx;
  padding-bottom: env(safe-area-inset-bottom);
}
