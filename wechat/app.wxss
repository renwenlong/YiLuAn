@import './styles/variables.wxss';

/* ============================================
 * 全局基础样式
 * ============================================ */

page {
  /* 向后兼容旧变量名 */
  --primary-color: var(--color-primary);
  --success-color: var(--color-success);
  --warning-color: var(--color-warning);
  --error-color: var(--color-danger);
  --text-primary: var(--color-text-primary);
  --text-secondary: var(--color-text-secondary);
  --text-hint: var(--color-text-hint);
  --bg-page: var(--color-bg-page);
  --bg-card: var(--color-bg-card);
  --border-color: var(--color-border);

  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  font-size: var(--font-size-body);
  color: var(--color-text-primary);
  background: var(--color-bg-page);
  box-sizing: border-box;
  line-height: var(--line-height-normal);
  -webkit-font-smoothing: antialiased;
}

/* ============================================
 * 布局容器
 * ============================================ */

.container {
  padding: var(--spacing-lg);
}

.page-container {
  min-height: 100vh;
  background: var(--color-bg-page);
}

/* ============================================
 * 卡片系统 — 三级卡片
 * ============================================ */

.card {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-md);
  box-shadow: var(--shadow-sm);
}

.card-elevated {
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-md);
  box-shadow: var(--shadow-md);
}

.card-flat {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-md);
  border: 2rpx solid var(--color-border-light);
}

/* ============================================
 * 按钮系统
 * ============================================ */

/* 主按钮 — 渐变蓝绿 */
.btn-primary {
  background: var(--gradient-primary);
  color: var(--color-text-white);
  border: none;
  border-radius: var(--radius-md);
  padding: 24rpx 0;
  font-size: var(--font-size-h2);
  font-weight: 600;
  text-align: center;
  width: 100%;
  box-shadow: var(--shadow-primary);
  transition: opacity var(--duration-fast) var(--ease-in-out);
  line-height: 1.2;
}

.btn-primary::after {
  border: none;
}

.btn-primary:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.btn-primary[disabled] {
  opacity: 0.4;
  box-shadow: none;
}

/* 次要按钮 */
.btn-secondary {
  background: var(--color-bg-page);
  color: var(--color-text-secondary);
  border: none;
  border-radius: var(--radius-md);
  padding: 24rpx 0;
  font-size: var(--font-size-h2);
  font-weight: 500;
  text-align: center;
  width: 100%;
  transition: background var(--duration-fast) var(--ease-in-out);
  line-height: 1.2;
}

.btn-secondary::after {
  border: none;
}

.btn-secondary:active {
  background: var(--color-border-light);
}

/* 幽灵按钮 */
.btn-ghost {
  background: transparent;
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary);
  border-radius: var(--radius-md);
  padding: 22rpx 0;
  font-size: var(--font-size-h2);
  font-weight: 500;
  text-align: center;
  width: 100%;
  transition: all var(--duration-fast) var(--ease-in-out);
  line-height: 1.2;
}

.btn-ghost::after {
  border: none;
}

.btn-ghost:active {
  background: var(--color-primary-light);
}

/* 危险按钮 */
.btn-danger {
  background: var(--color-danger);
  color: var(--color-text-white);
  border: none;
  border-radius: var(--radius-md);
  padding: 24rpx 0;
  font-size: var(--font-size-h2);
  font-weight: 600;
  text-align: center;
  width: 100%;
  box-shadow: var(--shadow-danger);
  transition: opacity var(--duration-fast) var(--ease-in-out);
  line-height: 1.2;
}

.btn-danger::after {
  border: none;
}

.btn-danger:active {
  opacity: 0.85;
}

/* 小号按钮修饰 */
.btn-sm {
  padding: 14rpx 28rpx;
  font-size: var(--font-size-caption);
  width: auto;
  border-radius: var(--radius-sm);
}

/* 按钮组 */
.btn-group {
  display: flex;
  gap: var(--spacing-md);
}

.btn-group > button,
.btn-group > view {
  flex: 1;
}

/* ============================================
 * 标题系统
 * ============================================ */

.section-title {
  font-size: var(--font-size-h2);
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: var(--spacing-md);
  line-height: var(--line-height-tight);
}

.section-subtitle {
  font-size: var(--font-size-caption);
  color: var(--color-text-hint);
  margin-top: var(--spacing-xs);
  line-height: var(--line-height-normal);
}

/* ============================================
 * Flex 工具
 * ============================================ */

.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.flex-wrap {
  flex-wrap: wrap;
}

.flex-1 {
  flex: 1;
}

.gap-xs { gap: var(--spacing-xs); }
.gap-sm { gap: var(--spacing-sm); }
.gap-md { gap: var(--spacing-md); }
.gap-lg { gap: var(--spacing-lg); }

/* ============================================
 * 表单增强
 * ============================================ */

.form-group {
  margin-bottom: var(--spacing-md);
}

.form-label {
  font-size: var(--font-size-caption);
  color: var(--color-text-secondary);
  font-weight: 500;
  margin-bottom: var(--spacing-xs);
  display: block;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background: var(--color-bg-input);
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-md);
  padding: 0 var(--spacing-lg);
  font-size: var(--font-size-body);
  color: var(--color-text-primary);
  transition: border-color var(--duration-fast) var(--ease-in-out),
              box-shadow var(--duration-fast) var(--ease-in-out);
  box-sizing: border-box;
}

.form-input:focus,
.form-input-focus {
  border-color: var(--color-border-focus);
  box-shadow: 0 0 0 4rpx rgba(24, 144, 255, 0.1);
  background: var(--color-bg-card);
}

.form-textarea {
  width: 100%;
  min-height: 180rpx;
  background: var(--color-bg-input);
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-md);
  padding: var(--spacing-md);
  font-size: var(--font-size-body);
  color: var(--color-text-primary);
  line-height: var(--line-height-relaxed);
  box-sizing: border-box;
}

/* ============================================
 * 徽标与标签
 * ============================================ */

.badge {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: var(--radius-full);
  font-size: var(--font-size-small);
  font-weight: 500;
  line-height: 1.4;
}

.badge-primary {
  background: var(--color-primary-light);
  color: var(--color-primary);
}

.badge-success {
  background: var(--color-success-light);
  color: var(--color-success);
}

.badge-warning {
  background: var(--color-warning-light);
  color: var(--color-warning);
}

.badge-danger {
  background: var(--color-danger-light);
  color: var(--color-danger);
}

/* 小圆点标记 */
.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.dot-primary { background: var(--color-primary); }
.dot-success { background: var(--color-success); }
.dot-warning { background: var(--color-warning); }
.dot-danger { background: var(--color-danger); }

/* ============================================
 * 分割线
 * ============================================ */

.divider {
  height: 2rpx;
  background: var(--color-border-light);
  margin: var(--spacing-md) 0;
}

.divider-thin {
  height: 1rpx;
  background: var(--color-border-light);
}

/* ============================================
 * 骨架屏动画
 * ============================================ */

.skeleton {
  background: linear-gradient(
    90deg,
    var(--color-bg-skeleton) 25%,
    #F3F4F6 50%,
    var(--color-bg-skeleton) 75%
  );
  background-size: 400% 100%;
  animation: skeleton-loading 1.5s ease infinite;
  border-radius: var(--radius-sm);
}

@keyframes skeleton-loading {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

.skeleton-text {
  height: 28rpx;
  margin-bottom: 16rpx;
}

.skeleton-title {
  height: 36rpx;
  width: 60%;
  margin-bottom: 24rpx;
}

.skeleton-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
}

.skeleton-card {
  height: 200rpx;
  margin-bottom: 24rpx;
}

/* ============================================
 * 空状态
 * ============================================ */

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-2xl) var(--spacing-lg);
}

.empty-state-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: var(--spacing-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 120rpx;
  opacity: 0.3;
}

.empty-state-title {
  font-size: var(--font-size-h2);
  font-weight: 500;
  color: var(--color-text-secondary);
  margin-bottom: var(--spacing-xs);
}

.empty-state-desc {
  font-size: var(--font-size-caption);
  color: var(--color-text-hint);
  text-align: center;
  line-height: var(--line-height-relaxed);
}

/* ============================================
 * 页面过渡
 * ============================================ */

.fade-in {
  animation: fadeIn var(--duration-normal) var(--ease-out);
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.slide-up {
  animation: slideUp var(--duration-normal) var(--ease-spring);
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

/* ============================================
 * Safe Area
 * ============================================ */

.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

.safe-bottom-fixed {
  padding-bottom: calc(env(safe-area-inset-bottom) + 24rpx);
}


/* ============================================
 * Polish Batch 2026-04-23 (P-03..P-12)
 * Design intent: 补齐全局交互反馈 / 无障碍 / 深色模式
 * ============================================ */

/* P-05: 全局按钮点击态视觉反馈 */
.btn,
button,
.polish-btn {
  transition: opacity var(--duration-fast) var(--ease-out),
              transform var(--duration-fast) var(--ease-out);
}
.btn:active,
button:active,
.polish-btn:active {
  opacity: 0.7;
  transform: scale(0.98);
}

/* P-04: 金额展示统一 (brand orange + bold + 36rpx) */
.polish-amount,
.amount,
.order-amount,
.wallet-amount {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--color-accent); /* brand orange #FF7A45 */
  font-variant-numeric: tabular-nums;
}
.polish-amount--lg { font-size: 48rpx; }
.polish-amount--sm { font-size: 28rpx; }

/* P-06: loading 文案统一 (加载中 无省略号) */
.polish-loading {
  display: inline-flex;
  align-items: center;
  gap: var(--spacing-xs);
  color: var(--color-text-secondary);
  font-size: var(--font-size-caption);
}
.polish-loading::after {
  content: '';
  width: 12rpx;
  height: 12rpx;
  border: 2rpx solid var(--color-primary);
  border-top-color: transparent;
  border-radius: 50%;
  animation: polish-spin 0.8s linear infinite;
}
@keyframes polish-spin {
  to { transform: rotate(360deg); }
}

/* P-08: 表单内联错误提示 (替代散落的 toast) */
.polish-form-error {
  display: block;
  margin-top: var(--spacing-2xs);
  font-size: var(--font-size-small);
  color: var(--color-danger);
  line-height: var(--line-height-tight);
}

/* P-11: 卡片圆角 token 化 */
.polish-card,
.order-card,
.companion-card,
.wallet-card {
  border-radius: var(--radius-lg); /* 统一 16rpx */
}

/* P-10: 无障碍 — 纯图标按钮最小可点击区域 + 焦点环 */
.polish-icon-btn {
  min-width: 88rpx;
  min-height: 88rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}
.polish-icon-btn:focus-visible {
  outline: 3rpx solid var(--color-primary);
  outline-offset: 2rpx;
}

/* P-12: 深色模式适配 (微信小程序 theme=dark) */
@media (prefers-color-scheme: dark) {
  page {
    --color-bg-page: #141414;
    --color-bg-card: #1F1F1F;
    --color-bg-input: #262626;
    --color-bg-hover: #262626;
    --color-text-primary: #F5F5F5;
    --color-text-secondary: #BFBFBF;
    --color-text-hint: #8C8C8C;
    --color-border: #303030;
    --color-border-light: #262626;
  }
}

/* P-09: 页面标题栏默认样式(配合 app.json 的 navigationBarTextStyle=black) */
.polish-navbar-spacer {
  height: calc(env(safe-area-inset-top) + 44px);
}
