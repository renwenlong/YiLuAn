# ============================================================
# 医路安（YiLuAn）后端配置模板
# 复制本文件为 .env 并根据实际环境修改
# ============================================================

# ---------- 基础配置 ----------
# 运行环境：development / production
ENVIRONMENT=development
# 调试模式：生产环境必须设为 false
DEBUG=true

# ---------- 数据库 ----------
# PostgreSQL 连接地址（异步驱动 asyncpg）
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/yiluan

# ---------- Redis ----------
# Redis 连接地址，用于缓存与会话
REDIS_URL=redis://localhost:6379/0

# ---------- JWT ----------
# ⚠️ 生产环境必须修改！请使用随机生成的强密钥（≥32字符）
# 示例生成命令：python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=dev-secret-key-change-in-production

# ---------- CORS ----------
# 允许的跨域来源，JSON 数组格式
CORS_ORIGINS=["*"]

# ---------- 微信支付 ----------
# 支付提供商：mock（开发测试）/ wechat（生产）
PAYMENT_PROVIDER=mock
# 微信支付商户号
WECHAT_PAY_MCH_ID=
# 商户 API 证书序列号
WECHAT_PAY_SERIAL_NO=
# v3 API 密钥（32字节）
WECHAT_PAY_V3_KEY=
# 商户私钥文件路径（apiclient_key.pem）
WECHAT_PAY_PRIVATE_KEY_PATH=
# 微信支付关联的 APPID
WECHAT_PAY_APPID=

# ---------- 短信服务 ----------
# 短信提供商：mock（开发测试）/ aliyun / tencent
SMS_PROVIDER=mock

# -- 阿里云短信 --
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=

# -- 腾讯云短信 --
TENCENT_SMS_SECRET_ID=
TENCENT_SMS_SECRET_KEY=
TENCENT_SMS_APP_ID=
TENCENT_SMS_SIGN_NAME=
TENCENT_SMS_TEMPLATE_ID=

# ---------- PII / 隐私加密 (ADR-0029) ----------
# 紧急联系人手机号 / 紧急事件被叫号码会用 AES-256-GCM 加密落库。
# 下面的 envelope key 必须是 base64 编码的 32 字节 (AES-256)；生产从 KMS / Secret Manager 注入。
# 生成 dev 用法： python -c "import os, base64; print(base64.b64encode(os.urandom(32)).decode())"
PII_ENVELOPE_KEY=eHh4eHh4eHh4eHh4eHh4eHh4eHh4eHh4eHh4eHh4eHh4eA==
# phone_hash 用的 salt（HMAC-SHA256），生产必须 override 成高熵随机串
PII_HASH_SALT=yiluan-dev-salt-do-not-use-in-prod
