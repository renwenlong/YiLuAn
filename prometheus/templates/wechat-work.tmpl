{{- end }}

- **级别:** {{ .CommonLabels.severity | default "warning" }}
- **服务:** {{ .CommonLabels.service | default "-" }}
- **实例:** {{ .CommonLabels.instance | default "-" }}
- **起始:** {{ .StartsAt }}
{{ if eq .Status "resolved" -}}
- **结束:** {{ .EndsAt }}
{{- end }}

{{ range .Alerts -}}
> {{ .Annotations.summary | default .Labels.alertname }}
{{ if .Annotations.description -}}
> {{ .Annotations.description }}
{{ end -}}
{{ end }}

